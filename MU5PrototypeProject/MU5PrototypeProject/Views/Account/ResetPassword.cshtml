@model ResetPasswordViewModel

@{
    ViewData["Title"] = "Reset Password";
}

<section class="authShell">
    <div class="authPanel authPanelWide">
        <div class="authBadge">Account Recovery</div>
        <h1 class="authTitle">Reset Password</h1>
        <p class="authLead">Choose a new password for your staff account. Strong passwords use upper and lower case letters, numbers, and symbols.</p>

        <form asp-action="ResetPassword" method="post" class="authForm">
            <div asp-validation-summary="ModelOnly" class="authValidation" role="alert"></div>

            <input asp-for="Code" type="hidden" />

            <div class="authField">
                <label asp-for="Email" class="form-label authLabel"></label>
                <input asp-for="Email" class="form-control authInput" autocomplete="username" readonly />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="authField">
                <label asp-for="NewPassword" class="form-label authLabel"></label>
                <input asp-for="NewPassword" class="form-control authInput" autocomplete="new-password" />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>

            <div class="authField">
                <label asp-for="ConfirmNewPassword" class="form-label authLabel"></label>
                <input asp-for="ConfirmNewPassword" class="form-control authInput" autocomplete="new-password" />
                <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
            </div>

            <div class="authActions">
                <button type="submit" class="mu-btn mu-btn-accent authSubmit">Save new password</button>
                <a asp-action="Login" class="mu-btn mu-btn-secondary authSubmit">Back to login</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
