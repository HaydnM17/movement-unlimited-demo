@{
    ViewData["Title"] = "Access Denied";
}

<section class="authShell">
    <div class="authPanel authPanelWide">
        <div class="authBadge">Restricted</div>
        <h1 class="authTitle">Access Denied</h1>
        <p class="authLead">You are signed in, but your account does not have permission to open that page.</p>
        <div class="authActions">
            <a asp-controller="Home" asp-action="Index" class="mu-btn mu-btn-accent">Return to Dashboard</a>
        </div>
    </div>
</section>
