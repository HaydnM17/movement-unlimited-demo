@{
    ViewData["Title"] = "Password Updated";
}

<section class="authShell">
    <div class="authPanel">
        <div class="authBadge">Account Recovery</div>
        <h1 class="authTitle">Password Updated</h1>
        <p class="authLead">Your password has been reset. You can return to the login screen and sign in with your new password now.</p>

        <div class="authActions">
            <a asp-action="Login" class="mu-btn mu-btn-accent authSubmit">Back to login</a>
        </div>
    </div>
</section>
