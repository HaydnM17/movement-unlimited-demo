@model ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
}

<section class="authShell">
    <div class="authPanel">
        <div class="authBadge">Account Recovery</div>
        <h1 class="authTitle">Forgot Password</h1>
        <p class="authLead">Enter your staff email address and we will prepare a password reset for your account if it is active.</p>

        <form asp-action="ForgotPassword" method="post" class="authForm">
            <div asp-validation-summary="ModelOnly" class="authValidation" role="alert"></div>

            <div class="authField">
                <label asp-for="Email" class="form-label authLabel"></label>
                <input asp-for="Email" class="form-control authInput" autocomplete="username" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="authActions">
                <button type="submit" class="mu-btn mu-btn-accent authSubmit">Send reset instructions</button>
                <a asp-action="Login" class="mu-btn mu-btn-secondary authSubmit">Back to login</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
