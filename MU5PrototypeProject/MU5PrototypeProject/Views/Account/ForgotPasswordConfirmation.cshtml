@model ForgotPasswordConfirmationViewModel

@{
    ViewData["Title"] = "Reset Instructions";
}

<section class="authShell">
    <div class="authPanel authPanelWide">
        <div class="authBadge">Account Recovery</div>
        <h1 class="authTitle">Check Your Reset Instructions</h1>
        <p class="authLead">If an active staff account matches the email you entered, password reset instructions are ready for that account.</p>

        @if (Model.ShowPreviewLink)
        {
            <div class="authPreview" role="status">
                <h2 class="authPreviewTitle">Testing-only reset preview</h2>
                <p class="authPreviewText">This environment is using on-screen password reset preview mode. This shortcut must stay disabled in production.</p>
                <a href="@Model.PreviewResetUrl" class="mu-btn mu-btn-accent">Open reset link</a>
            </div>
        }

        <div class="authActions">
            <a asp-action="Login" class="mu-btn mu-btn-secondary authSubmit">Back to login</a>
        </div>
    </div>
</section>
