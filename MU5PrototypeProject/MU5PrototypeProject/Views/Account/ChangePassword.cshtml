@model ChangePasswordViewModel

@{
    ViewData["Title"] = "Change Password";
}

<section class="authShell">
    <div class="authPanel authPanelWide">
        <div class="authBadge">Account Security</div>
        <h1 class="authTitle">Change Password</h1>
        <p class="authLead">Choose a new password for your account. Strong passwords use a mix of upper and lower case letters, numbers, and symbols.</p>

        <form asp-action="ChangePassword" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="authForm">
            <div asp-validation-summary="ModelOnly" class="authValidation" role="alert"></div>

            <div class="authField">
                <label asp-for="CurrentPassword" class="form-label authLabel"></label>
                <div class="accountPasswordInputWrap">
                    <input asp-for="CurrentPassword" class="form-control authInput accountPasswordInput" autocomplete="current-password" />
                    <button type="button"
                            class="accountPasswordToggle"
                            data-target="CurrentPassword"
                            data-label-show="Show password"
                            data-label-hide="Hide password"
                            aria-label="Show password"
                            aria-pressed="false"
                            title="Show password">
                        <svg class="accountPasswordToggleIcon accountPasswordToggleIcon-show" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M2 12s3.6-6 10-6 10 6 10 6-3.6 6-10 6-10-6-10-6Z"></path>
                            <circle cx="12" cy="12" r="3.25"></circle>
                        </svg>
                        <svg class="accountPasswordToggleIcon accountPasswordToggleIcon-hide" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M3 3l18 18"></path>
                            <path d="M10.6 6.3A10.7 10.7 0 0 1 12 6c6.4 0 10 6 10 6a17 17 0 0 1-4 4.5"></path>
                            <path d="M6.2 6.8C3.7 8.5 2 12 2 12s3.6 6 10 6c1.4 0 2.7-.3 3.8-.8"></path>
                            <path d="M9.9 9.9a3.2 3.2 0 0 0 4.2 4.2"></path>
                        </svg>
                        <span class="visually-hidden">Toggle password visibility</span>
                    </button>
                </div>
                <span asp-validation-for="CurrentPassword" class="text-danger"></span>
            </div>

            <div class="authField">
                <label asp-for="NewPassword" class="form-label authLabel"></label>
                <div class="accountPasswordInputWrap">
                    <input asp-for="NewPassword" class="form-control authInput accountPasswordInput" autocomplete="new-password" />
                    <button type="button"
                            class="accountPasswordToggle"
                            data-target="NewPassword"
                            data-label-show="Show password"
                            data-label-hide="Hide password"
                            aria-label="Show password"
                            aria-pressed="false"
                            title="Show password">
                        <svg class="accountPasswordToggleIcon accountPasswordToggleIcon-show" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M2 12s3.6-6 10-6 10 6 10 6-3.6 6-10 6-10-6-10-6Z"></path>
                            <circle cx="12" cy="12" r="3.25"></circle>
                        </svg>
                        <svg class="accountPasswordToggleIcon accountPasswordToggleIcon-hide" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M3 3l18 18"></path>
                            <path d="M10.6 6.3A10.7 10.7 0 0 1 12 6c6.4 0 10 6 10 6a17 17 0 0 1-4 4.5"></path>
                            <path d="M6.2 6.8C3.7 8.5 2 12 2 12s3.6 6 10 6c1.4 0 2.7-.3 3.8-.8"></path>
                            <path d="M9.9 9.9a3.2 3.2 0 0 0 4.2 4.2"></path>
                        </svg>
                        <span class="visually-hidden">Toggle password visibility</span>
                    </button>
                </div>
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>

            <div class="authField">
                <label asp-for="ConfirmNewPassword" class="form-label authLabel"></label>
                <div class="accountPasswordInputWrap">
                    <input asp-for="ConfirmNewPassword" class="form-control authInput accountPasswordInput" autocomplete="new-password" />
                    <button type="button"
                            class="accountPasswordToggle"
                            data-target="ConfirmNewPassword"
                            data-label-show="Show password"
                            data-label-hide="Hide password"
                            aria-label="Show password"
                            aria-pressed="false"
                            title="Show password">
                        <svg class="accountPasswordToggleIcon accountPasswordToggleIcon-show" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M2 12s3.6-6 10-6 10 6 10 6-3.6 6-10 6-10-6-10-6Z"></path>
                            <circle cx="12" cy="12" r="3.25"></circle>
                        </svg>
                        <svg class="accountPasswordToggleIcon accountPasswordToggleIcon-hide" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M3 3l18 18"></path>
                            <path d="M10.6 6.3A10.7 10.7 0 0 1 12 6c6.4 0 10 6 10 6a17 17 0 0 1-4 4.5"></path>
                            <path d="M6.2 6.8C3.7 8.5 2 12 2 12s3.6 6 10 6c1.4 0 2.7-.3 3.8-.8"></path>
                            <path d="M9.9 9.9a3.2 3.2 0 0 0 4.2 4.2"></path>
                        </svg>
                        <span class="visually-hidden">Toggle password visibility</span>
                    </button>
                </div>
                <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
            </div>

            <div class="authActions">
                <button type="submit" class="mu-btn mu-btn-accent">Save Password</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            document.querySelectorAll('.accountPasswordToggle').forEach(function (button) {
                button.addEventListener('click', function () {
                    var targetId = button.getAttribute('data-target');
                    var input = document.getElementById(targetId);
                    if (!input) {
                        return;
                    }

                    var showing = input.type === 'text';
                    var nextIsShowing = !showing;
                    var nextType = nextIsShowing ? 'text' : 'password';
                    var nextLabel = nextIsShowing
                        ? button.getAttribute('data-label-hide')
                        : button.getAttribute('data-label-show');

                    input.type = nextType;
                    button.setAttribute('aria-pressed', nextIsShowing ? 'true' : 'false');
                    button.setAttribute('aria-label', nextLabel);
                    button.setAttribute('title', nextLabel);
                });
            });
        })();
    </script>
}
