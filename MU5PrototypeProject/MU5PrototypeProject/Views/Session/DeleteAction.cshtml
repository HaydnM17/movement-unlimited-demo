@model MU5PrototypeProject.Models.Action

<h2>Delete Excercise</h2>

<p>Are you sure you want to delete this Excercise?</p>

<div class="mb-3">
    <strong>Exercise:</strong> @Model.Exercise?.ExerciseName
</div>
<div class="mb-3">
    <strong>Springs:</strong> @Model.Springs
</div>
<div class="mb-3">
    <strong>Notes:</strong> @Model.Notes
</div>

<form asp-action="DeleteAction" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ID" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Edit" asp-route-id="@ViewData["SessionID"]" class="btn btn-secondary">Cancel</a>
</form>