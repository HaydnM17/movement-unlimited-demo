                                    <textarea asp-for="SessionNotes.ObjectiveFindings" class="form-control" data-history-field="SessionNotes.ObjectiveFindings"></textarea>
                                    <span asp-validation-for="SessionNotes.ObjectiveFindings" class="text-danger"></span>
                                </div>
                                <div class="col-12">
                                        <label asp-for="SessionNotes.Plan" class="form-label"></label><span class="text-danger"> *</span>
                                    <textarea asp-for="SessionNotes.Plan" class="form-control" data-history-field="SessionNotes.Plan"></textarea>
