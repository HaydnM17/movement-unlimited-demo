            else
            {
                <div class="detailFields">
                    <div class="detailField"><span class="detailFieldLabel">Head Rest</span><div class="detailFieldValue" data-history-field="Accessories.HeadPad">@Model.Accessories!.HeadPad</div></div>
                    <div class="detailField"><span class="detailFieldLabel">Straps/Handles</span><div class="detailFieldValue" data-history-field="Accessories.StrapsOrHandles">@Model.Accessories.StrapsOrHandles</div></div>
                    <div class="detailField"><span class="detailFieldLabel">Gear Bar</span><div class="detailFieldValue" data-history-field="Accessories.GearBar">@Model.Accessories.GearBar</div></div>
                    <div class="detailField"><span class="detailFieldLabel">Stopper Settings</span><div class="detailFieldValue" data-history-field="Accessories.StopperSettings">@Model.Accessories.StopperSettings</div></div>
                    <div class="detailField"><span class="detailFieldLabel">Rubber Pads</span><div class="detailFieldValue" data-history-field="Accessories.RubberPads" data-history-format="yesno">@YesNo(Model.Accessories.RubberPads)</div></div>
                    <div class="detailField"><span class="detailFieldLabel">Head Rest</span><div class="detailFieldValue" data-history-field="Accessories.HeadRest" data-history-format="yesno">@YesNo(Model.Accessories.HeadRest)</div></div>
                    <div class="detailField"><span class="detailFieldLabel">Towel</span><div class="detailFieldValue" data-history-field="Accessories.Towel" data-history-format="yesno">@YesNo(Model.Accessories.Towel)</div></div>
                    <div class="detailField"><span class="detailFieldLabel">Posture Pillow</span><div class="detailFieldValue" data-history-field="Accessories.PosturePillow" data-history-format="yesno">@YesNo(Model.Accessories.PosturePillow)</div></div>
                </div>
