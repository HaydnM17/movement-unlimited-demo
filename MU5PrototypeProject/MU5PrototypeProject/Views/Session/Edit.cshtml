    .editShell.history-reference-mode .detailTextValue[data-history-field] {
        color: #6c757d;
    }

    .editShell.history-reference-mode .form-control[data-history-field],
    .editShell.history-reference-mode .workflowChoice {
        background-color: #f3f4f6;
        border-color: #d7dde5;
    }

    .editShell.history-reference-mode .form-check-input[data-history-field] {
        opacity: 0.65;
    }

    .history-disabled-action {
        pointer-events: none;
    }

    .editShell.history-reference-mode button:disabled:not(.historyNavButton),
    .editShell.history-reference-mode .history-disabled-action {
        opacity: 0.45;
        cursor: not-allowed;
        box-shadow: none;
        filter: saturate(0.35);
    }

    .historyViewerCard.is-compact {
        background: #fbfbfc;
        border-color: #e6e8ec;
        padding-bottom: 0.9rem;
    }

    .historyViewerCard.is-compact .sectionCardTitle {
        font-size: 1rem;
    }

    .historyViewerCard.is-compact .fieldNote {
        font-size: 0.92rem;
    }

    .generalInfoCard.is-compact .detailFields {
        gap: 0.75rem 1rem;
    }

    .generalInfoCard.is-compact .detailFieldValue {
        font-size: 0.95rem;
    }

    .loggedSection .sectionCardHeader {
        align-items: center;
    }

    .actionsHeaderMeta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        align-items: center;
        justify-content: space-between;
    }

    .actionsParticipantHeader {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.85rem;
    }

    .actionGridCompact {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 12px;
    }

    .actionCardCompact {
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 12px;
        background-color: #f9f9f9;
    }

    .actionCardTitle {
        margin: 0 0 0.5rem;
        font-size: 1rem;
    }

    .actionMetaRow {
        margin-bottom: 0.35rem;
        font-size: 0.95rem;
    }

    .actionNotesCompact {
        margin: 0.65rem 0 0;
        padding: 0.65rem 0.75rem;
        background-color: white;
        border-radius: 6px;
        border-left: 3px solid #007bff;
    }

    .actionFooterCompact {
        display: flex;
        gap: 8px;
        padding-top: 0.75rem;
        margin-top: 0.75rem;
        border-top: 1px solid #dee2e6;
    }

    .historyViewerMeta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem 1rem;
        margin-top: 0.65rem;
    }

    .historyViewerMetaItem {
        font-size: 0.92rem;
        color: #5f6b7a;
    }

    .historyNavButton:disabled {
        opacity: 0.45;
        cursor: not-allowed;
        box-shadow: none;
    }

</style>

<form asp-action="Edit" class="sectionStack editShell" id="pageForm">
    <input type="hidden" asp-for="ID" />
    <input type="hidden" asp-for="PrimarySessionClientID" />
    <input type="hidden" asp-for="SecondarySessionClientID" />
    <input type="hidden" id="addActionSessionClientId" name="addActionSessionClientId" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    @if (useCompletionAccordionLayout)
    {
        @if (!string.IsNullOrWhiteSpace(completedOnlyAccessMessage))
        {
            <div class="formSectionCard">
                <p class="mb-0">@completedOnlyAccessMessage</p>
            </div>
        }

        <div class="accordion detailAccordion mb-4" id="sessionEditCompletionAccordion">
            <div class="accordion-item">
                <h2 class="accordion-header" id="headingEditGeneralInfo">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseEditGeneralInfo" aria-expanded="false" aria-controls="collapseEditGeneralInfo">General Info</button>
                </h2>
                <div id="collapseEditGeneralInfo" class="accordion-collapse collapse" aria-labelledby="headingEditGeneralInfo">
                    <div class="accordion-body">
                        @{
                            await RenderGeneralInfoBody();
                        }
                    </div>
                </div>
            </div>
            @if (showLaterStageSections)
            {
                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingEditSessionNotes">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseEditSessionNotes" aria-expanded="false" aria-controls="collapseEditSessionNotes">Session Notes</button>
                    </h2>
                    <div id="collapseEditSessionNotes" class="accordion-collapse collapse" aria-labelledby="headingEditSessionNotes">
                        <div class="accordion-body">
                            @{
                                await RenderSessionNotesBody();
                            }
                        </div>
                    </div>
                </div>
                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingEditAccessories">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseEditAccessories" aria-expanded="false" aria-controls="collapseEditAccessories">Accessories</button>
                    </h2>
                    <div id="collapseEditAccessories" class="accordion-collapse collapse" aria-labelledby="headingEditAccessories">
                        <div class="accordion-body">
                            @{
                                await RenderAccessoriesBody();
                            }
                        </div>
                    </div>
                </div>
                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingEditExercises">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseEditExercises" aria-expanded="false" aria-controls="collapseEditExercises">Exercises</button>
                    </h2>
                    <div id="collapseEditExercises" class="accordion-collapse collapse" aria-labelledby="headingEditExercises">
                        <div class="accordion-body">
                            <div id="historyActionsContainer">
                                @{
                                    await RenderExercisesBody();
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingEditNextSteps">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseEditNextSteps" aria-expanded="false" aria-controls="collapseEditNextSteps">Next Steps</button>
                    </h2>
                    <div id="collapseEditNextSteps" class="accordion-collapse collapse" aria-labelledby="headingEditNextSteps">
                        <div class="accordion-body">
                            @{
                                await RenderNextStepsBody();
                            }
                        </div>
                    </div>
                </div>
            }
            <div class="accordion-item" data-history-viewer-container hidden>
                <h2 class="accordion-header" id="headingEditHistory">
                    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseEditHistory" aria-expanded="true" aria-controls="collapseEditHistory">Previous Session Viewer</button>
                </h2>
                <div id="collapseEditHistory" class="accordion-collapse collapse show" aria-labelledby="headingEditHistory">
                    <div class="accordion-body">
                        @{
                            await RenderPreviousSessionViewerBody();
                        }
                    </div>
                </div>
            </div>
            @if (activeStage == SessionStatus.Completed && isPhysio)
            {
                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingEditPhysioInfo">
                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseEditPhysioInfo" aria-expanded="true" aria-controls="collapseEditPhysioInfo">Physio Info</button>
                    </h2>
                    <div id="collapseEditPhysioInfo" class="accordion-collapse collapse show" aria-labelledby="headingEditPhysioInfo">
                        <div class="accordion-body">
                            @{
                                await RenderPhysioInfoBody();
                            }
                        </div>
                    </div>
                </div>
            }
            @if (activeStage == SessionStatus.Completed)
            {
                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingEditAdminComplete">
                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseEditAdminComplete" aria-expanded="true" aria-controls="collapseEditAdminComplete">Admin Complete</button>
                    </h2>
                    <div id="collapseEditAdminComplete" class="accordion-collapse collapse show" aria-labelledby="headingEditAdminComplete">
                        <div class="accordion-body">
                            @{
                                await RenderAdminCompleteBody();
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
    <div class="formSectionCard generalInfoCard @(isLoggedStage ? "is-compact" : null)">
        <div class="sectionCardHeader">
            <h2 class="sectionCardTitle">General Info</h2>
        </div>
        @if (allowGeneralInfoEditing)
        {
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="SessionType" class="form-label"></label>
                    <select asp-for="SessionType" class="form-control" asp-items="Html.GetEnumSelectList<SessionType>()"></select>
                    <span asp-validation-for="SessionType" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="SessionDate" class="form-label"></label>
                    <input asp-for="SessionDate" class="form-control" type="date" lang="en-CA" />
                    <span asp-validation-for="SessionDate" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="TrainerID" class="form-label"></label>
                    <select asp-for="TrainerID" class="form-control" asp-items="ViewBag.TrainerID">
                            <option value="">Select a Teacher</option>
                    </select>
                    <span asp-validation-for="TrainerID" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="ClientID" class="form-label"></label>
                    <select asp-for="ClientID" class="form-control" asp-items="ViewBag.ClientID">
                        <option value="">Select a Client</option>
                    </select>
                    <span asp-validation-for="ClientID" class="text-danger"></span>
                </div>
                <div class="col-md-4 semiPrivateOnly">
                    <label asp-for="Client2ID" class="form-label"></label>
                    <select asp-for="Client2ID" class="form-control" asp-items="ViewBag.ClientID">
                        <option value="">Select a Second Client</option>
                    </select>
                    <span asp-validation-for="Client2ID" class="text-danger"></span>
                </div>
            </div>
        }
        else
        {
            <div class="detailFields">
                <div class="detailField"><span class="detailFieldLabel">Session Type</span><div class="detailFieldValue">@Model.SessionType</div></div>
                <div class="detailField"><span class="detailFieldLabel">Session Date (YYYY-MM-DD)</span><div class="detailFieldValue">@Model.SessionDate.ToString("yyyy-MM-dd")</div></div>
                    <div class="detailField"><span class="detailFieldLabel">Teacher</span><div class="detailFieldValue">@LookupText(ViewBag.TrainerID, Model.TrainerID)</div></div>
                <div class="detailField"><span class="detailFieldLabel">Client</span><div class="detailFieldValue">@LookupText(ViewBag.ClientID, Model.ClientID)</div></div>
                @if (isSemiPrivate)
                {
                    <div class="detailField"><span class="detailFieldLabel">Client 2</span><div class="detailFieldValue">@LookupText(ViewBag.ClientID, Model.Client2ID)</div></div>
                }
            </div>
        }
    </div>

    @if (currentStatus == SessionStatus.Opened)
    {
        <div class="formSectionCard historyViewerCard @(isLoggedStage ? "is-compact" : null)" data-history-viewer-container hidden>
            <div class="sectionCardHeader">
                <h2 class="sectionCardTitle">Previous Session Viewer</h2>
            </div>
            <div class="d-flex flex-wrap align-items-center gap-2">
                <button type="button" id="historyPreviousButton" class="mu-btn mu-btn-secondary historyNavButton" disabled>Previous</button>
                <button type="button" id="historyNextButton" class="mu-btn mu-btn-secondary historyNavButton" disabled>Next</button>
                <span id="historyStatusLabel" class="fieldNote mb-0">Current session values</span>
            </div>
            <div class="historyViewerMeta">
                <span id="historyCountLabel" class="historyViewerMetaItem">Previous Sessions: -</span>
            </div>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(completedOnlyAccessMessage))
    {
        <div class="formSectionCard">
            <p class="mb-0">@completedOnlyAccessMessage</p>
        </div>
    }

    @if (showOpenedFutureDateMessage || showOpenedRoleMessage)
    {
        <div class="formSectionCard">
            <p class="mb-0">
                @(showOpenedFutureDateMessage
                    ? "This session cannot be moved to Logged yet because the session date is in the future. Logged sessions must be dated today or earlier."
                    : "This session is currently Opened. Logged-stage work is not available for your account.")
            </p>
        </div>
    }

    @if (showLaterStageSections)
    {
        <div class="formSectionCard">
            <div class="sectionCardHeader">
                <h2 class="sectionCardTitle">Session Notes</h2>
            </div>
