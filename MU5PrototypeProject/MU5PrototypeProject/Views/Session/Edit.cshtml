                                <div class="detailField"><span class="detailFieldLabel">Goals</span><div class="detailFieldValue detailTextValue" data-history-field="SessionNotes.Goals">@(string.IsNullOrWhiteSpace(Model.SessionNotes.Goals) ? "-" : Model.SessionNotes.Goals)</div></div>
                                <div class="detailField"><span class="detailFieldLabel">Sessions/Week</span><div class="detailFieldValue" data-history-field="SessionsPerWeekRecommended">@(Model.SessionsPerWeekRecommended?.ToString() ?? "-")</div></div>
                                <div class="detailField"><span class="detailFieldLabel">General Comments</span><div class="detailFieldValue detailTextValue" data-history-field="SessionNotes.GeneralComments">@(string.IsNullOrWhiteSpace(Model.SessionNotes.GeneralComments) ? "-" : Model.SessionNotes.GeneralComments)</div></div>
                                <div class="detailField"><span class="detailFieldLabel">Subjective Reports</span><div class="detailFieldValue detailTextValue" data-history-field="SessionNotes.SubjectiveReports">@(string.IsNullOrWhiteSpace(Model.SessionNotes.SubjectiveReports) ? "-" : Model.SessionNotes.SubjectiveReports)</div></div>
                                <div class="detailField"><span class="detailFieldLabel">Objective Findings</span><div class="detailFieldValue detailTextValue" data-history-field="SessionNotes.ObjectiveFindings">@(string.IsNullOrWhiteSpace(Model.SessionNotes.ObjectiveFindings) ? "-" : Model.SessionNotes.ObjectiveFindings)</div></div>
                                <div class="detailField"><span class="detailFieldLabel">Plan</span><div class="detailFieldValue detailTextValue" data-history-field="SessionNotes.Plan">@(string.IsNullOrWhiteSpace(Model.SessionNotes.Plan) ? "-" : Model.SessionNotes.Plan)</div></div>
                            </div>
                        }
                    </div>
                    <div class="col-md-6">
                        <div class="workflowSectionHint">
                            <strong>Client 2</strong>
                        </div>
                        @if (activeStage == SessionStatus.Logged)
                        {
                            <div class="row g-3 mt-1">
                                <div class="col-12">
                                        <label asp-for="Client2SessionNotes.Goals" class="form-label"></label><span class="text-danger"> *</span>
                                    <textarea asp-for="Client2SessionNotes.Goals" class="form-control" data-history-field="Client2SessionNotes.Goals"></textarea>
                                    <span asp-validation-for="Client2SessionNotes.Goals" class="text-danger"></span>
                                </div>
                                <div class="col-12">
                                        <label for="Client2SessionsPerWeekRecommended" class="form-label">Sessions/Week</label><span class="text-danger"> *</span>
                                    <input asp-for="Client2SessionsPerWeekRecommended" class="form-control" min="1" data-history-field="Client2SessionsPerWeekRecommended" />
                                    <span asp-validation-for="Client2SessionsPerWeekRecommended" class="text-danger"></span>
                                </div>
                                <div class="col-12"><label asp-for="Client2SessionNotes.GeneralComments" class="form-label"></label><textarea asp-for="Client2SessionNotes.GeneralComments" class="form-control" data-history-field="Client2SessionNotes.GeneralComments"></textarea></div>
                                <div class="col-12">
                                        <label asp-for="Client2SessionNotes.SubjectiveReports" class="form-label"></label><span class="text-danger"> *</span>
                                    <textarea asp-for="Client2SessionNotes.SubjectiveReports" class="form-control" data-history-field="Client2SessionNotes.SubjectiveReports"></textarea>
                                    <span asp-validation-for="Client2SessionNotes.SubjectiveReports" class="text-danger"></span>
                                </div>
                                <div class="col-12">
                                        <label asp-for="Client2SessionNotes.ObjectiveFindings" class="form-label"></label><span class="text-danger"> *</span>
                                    <textarea asp-for="Client2SessionNotes.ObjectiveFindings" class="form-control" data-history-field="Client2SessionNotes.ObjectiveFindings"></textarea>
                                    <span asp-validation-for="Client2SessionNotes.ObjectiveFindings" class="text-danger"></span>
                                </div>
                                <div class="col-12">
                                        <label asp-for="Client2SessionNotes.Plan" class="form-label"></label><span class="text-danger"> *</span>
                                    <textarea asp-for="Client2SessionNotes.Plan" class="form-control" data-history-field="Client2SessionNotes.Plan"></textarea>
                                    <span asp-validation-for="Client2SessionNotes.Plan" class="text-danger"></span>
                                </div>
                            </div>
                        }
