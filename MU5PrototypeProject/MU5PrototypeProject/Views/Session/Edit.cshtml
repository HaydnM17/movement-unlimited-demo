                }

                openCompletionAccordionPane(targetPaneId);
            }

            function updateHistoryUi() {
                const hasClient = !!primaryClientId || (isSemiPrivateSession && !!secondaryClientId);
                const hasHistory = totalHistoryCount > 0;
                setHistoryViewerVisibility(historySummaryLoaded && hasClient && hasHistory);

                if (!historyPreviousButton || !historyNextButton || !historyStatusLabel) {
                    return;
                }

                updateHistoryMetaUi();

                historyPreviousButton.disabled = !historySummaryLoaded
                    || !hasClient
                    || !hasHistory
                    || currentOffset >= totalHistoryCount - 1;
                historyNextButton.disabled = currentOffset < 0;

                if (!hasClient || currentOffset < 0) {
                    historyStatusLabel.textContent = historySummaryLoaded && !hasHistory
                        ? "No previous sessions available"
                        : currentStateLabel;
                    setBrowsingState(false);
                    return;
                }

                const primaryHistory = historyCache.get(`primary:${currentOffset}`);
                const secondaryHistory = historyCache.get(`secondary:${currentOffset}`);
                const labelParts = [`Viewing previous session ${currentOffset + 1} of ${totalHistoryCount}`];

                if (isSemiPrivateSession && secondaryClientId) {
                    if (primaryHistory && primaryHistory.sessionDate) {
                        labelParts.push(`Client 1 ${primaryHistory.sessionDate}`);
                    } else {
                        labelParts.push("Client 1 no history");
                    }
                } else if (primaryHistory && primaryHistory.sessionDate) {
                    labelParts.push(primaryHistory.sessionDate);
                }

                if (isSemiPrivateSession && secondaryClientId) {
                    if (secondaryHistory && secondaryHistory.sessionDate) {
                        labelParts.push(`Client 2 ${secondaryHistory.sessionDate}`);
                    } else {
                        labelParts.push("Client 2 no history");
                    }
                }

                historyStatusLabel.textContent = labelParts.join(" | ");
                setBrowsingState(true);
                openRelevantHistoryPane();
            }

            async function fetchHistory(clientId, offset, cacheKey) {
                if (!clientId) {
                    return null;
                }

                if (historyCache.has(cacheKey)) {
                    return historyCache.get(cacheKey);
                }

                const url = `@Url.Action("ClientSessionHistory", "Session")?clientId=${encodeURIComponent(clientId)}&offset=${encodeURIComponent(offset)}&currentSessionId=${encodeURIComponent(currentSessionId)}&referenceDate=${encodeURIComponent(currentSessionDate)}`;
                const response = await fetch(url, {
                    headers: {
                        "X-Requested-With": "XMLHttpRequest"
                    }
                });

                if (!response.ok) {
                    throw new Error("Failed to load history.");
                }

                const data = await response.json();
                historyCache.set(cacheKey, data);
                return data;
            }

