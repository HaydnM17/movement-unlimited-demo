    async Task RenderExercisesBody()
    {
        var primaryActions = Model.ExistingActions
            .Where(a => a.SessionClientID == Model.PrimarySessionClientID
                || a.SessionClient?.ParticipantOrder == 1)
            .OrderBy(a => a.ID)
            .ToList();
        var secondaryActions = Model.ExistingActions
            .Where(a => a.SessionClientID == Model.SecondarySessionClientID
                || a.SessionClient?.ParticipantOrder == 2)
            .OrderBy(a => a.ID)
            .ToList();

        if (activeStage == SessionStatus.Logged)
        {
            <span asp-validation-for="SelectedExerciseIDs" class="text-danger"></span>
            @if (isSemiPrivate)
            {
                @foreach (var participantActions in new[] {
                    ("Client 1", Model.PrimarySessionClientID, primaryActions),
                    ("Client 2", Model.SecondarySessionClientID, secondaryActions)
                })
                {
                    <div class="actionsParticipantHeader">
                        <h3 class="sectionCardTitle mb-0" style="font-size: 1.05rem;">@participantActions.Item1</h3>
                        <button type="submit" name="Status" value="@activeStage" data-add-action-session-client-id="@participantActions.Item2" class="mu-btn mu-btn-primary mu-btn-sm">+ Add Exercise</button>
                    </div>
                    @if (participantActions.Item3.Any())
                    {
                        <div class="actionGridCompact" style="margin-bottom: 16px;">
                            @foreach (var action in participantActions.Item3)
                            {
                                <div class="actionCardCompact">
                                    <h4 class="actionCardTitle">@(action.Exercise?.ExerciseName ?? "Exercise")</h4>
                                    @if (action.Exercise?.Apparatus != null)
                                    {
                                        <div class="actionMetaRow"><strong>Apparatus:</strong> @action.Exercise.Apparatus.ApparatusName</div>
                                    }
                                    @if (!string.IsNullOrEmpty(action.Springs))
                                    {
                                        <div class="actionMetaRow"><strong>Springs:</strong> @action.Springs</div>
                                    }
                                    @if (action.ExerciseProps != null && action.ExerciseProps.Any())
                                    {
                                        <div class="actionMetaRow"><strong>Props:</strong> @string.Join(", ", action.ExerciseProps.Select(ep => ep.Prop?.PropName).Where(name => !string.IsNullOrWhiteSpace(name)))</div>
                                    }
                                    @if (!string.IsNullOrEmpty(action.Notes))
                                    {
                                        <div class="actionNotesCompact"><strong>Notes:</strong> @action.Notes</div>
                                    }
                                    <div class="actionFooterCompact">
                                        <a asp-action="EditAction" asp-route-id="@action.ID" class="mu-btn mu-btn-primary mu-btn-sm">Edit</a>
                                        <a asp-action="DeleteAction" asp-route-id="@action.ID" class="mu-btn mu-btn-danger mu-btn-sm" onclick="return confirm('Are you sure?')">Delete</a>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="detailEmpty">No Exercises have been added yet.</p>
                    }
                }
            }
            else
            {
                @if (primaryActions.Any())
                {
                    <div class="actionGridCompact">
                        @foreach (var action in primaryActions)
                        {
                            <div class="actionCardCompact">
                                <h4 class="actionCardTitle">@(action.Exercise?.ExerciseName ?? "Exercise")</h4>
                                @if (action.Exercise?.Apparatus != null)
                                {
                                    <div class="actionMetaRow"><strong>Apparatus:</strong> @action.Exercise.Apparatus.ApparatusName</div>
                                }
                                @if (!string.IsNullOrEmpty(action.Springs))
                                {
                                    <div class="actionMetaRow"><strong>Springs:</strong> @action.Springs</div>
                                }
                                @if (action.ExerciseProps != null && action.ExerciseProps.Any())
                                {
                                    <div class="actionMetaRow"><strong>Props:</strong> @string.Join(", ", action.ExerciseProps.Select(ep => ep.Prop?.PropName).Where(name => !string.IsNullOrWhiteSpace(name)))</div>
                                }
                                @if (!string.IsNullOrEmpty(action.Notes))
                                {
                                    <div class="actionNotesCompact"><strong>Notes:</strong> @action.Notes</div>
                                }
                                <div class="actionFooterCompact">
                                    <a asp-action="EditAction" asp-route-id="@action.ID" class="mu-btn mu-btn-primary mu-btn-sm">Edit</a>
                                    <a asp-action="DeleteAction" asp-route-id="@action.ID" class="mu-btn mu-btn-danger mu-btn-sm" onclick="return confirm('Are you sure?')">Delete</a>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="detailEmpty">No Exercises have been added yet.</p>
                }
            }
        }
        else if (isSemiPrivate)
        {
            @foreach (var participantActions in new[] { ("Client 1", primaryActions), ("Client 2", secondaryActions) })
            {
                <h3 class="sectionCardTitle" style="font-size: 1.05rem; margin-bottom: 12px;">@participantActions.Item1</h3>
                @if (participantActions.Item2.Any())
                {
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 15px; margin-bottom: 16px;">
                        @foreach (var action in participantActions.Item2)
                        {
                            <div style="border: 1px solid #dee2e6; border-radius: 4px; padding: 15px; background-color: #f9f9f9;">
                                <h4 style="margin-top: 0; margin-bottom: 10px;">@(action.Exercise?.ExerciseName ?? "Exercise")</h4>
                                @if (action.Exercise?.Apparatus != null)
                                {
                                    <div style="margin-bottom: 8px;"><strong>Apparatus:</strong> @action.Exercise.Apparatus.ApparatusName</div>
                                }
                                @if (!string.IsNullOrEmpty(action.Springs))
                                {
                                    <div style="margin-bottom: 8px;"><strong>Springs:</strong> @action.Springs</div>
                                }
                                @if (action.ExerciseProps != null && action.ExerciseProps.Any())
                                {
                                    <div style="margin-bottom: 8px;"><strong>Props:</strong> @string.Join(", ", action.ExerciseProps.Select(ep => ep.Prop?.PropName).Where(name => !string.IsNullOrWhiteSpace(name)))</div>
                                }
                                @if (!string.IsNullOrEmpty(action.Notes))
                                {
                                    <div style="margin-bottom: 10px; background-color: white; padding: 8px; border-radius: 3px; border-left: 3px solid #007bff;"><strong>Notes:</strong> @action.Notes</div>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="detailEmpty">No Exercises have been added yet.</p>
                }
            }
        }
        else if (primaryActions.Any())
        {
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 15px;">
                @foreach (var action in primaryActions)
                {
                    <div style="border: 1px solid #dee2e6; border-radius: 4px; padding: 15px; background-color: #f9f9f9;">
                        <h4 style="margin-top: 0; margin-bottom: 10px;">@(action.Exercise?.ExerciseName ?? "Exercise")</h4>
                        @if (action.Exercise?.Apparatus != null)
                        {
                            <div style="margin-bottom: 8px;"><strong>Apparatus:</strong> @action.Exercise.Apparatus.ApparatusName</div>
                        }
                        @if (!string.IsNullOrEmpty(action.Springs))
                        {
                            <div style="margin-bottom: 8px;"><strong>Springs:</strong> @action.Springs</div>
                        }
                        @if (action.ExerciseProps != null && action.ExerciseProps.Any())
                        {
                            <div style="margin-bottom: 8px;"><strong>Props:</strong> @string.Join(", ", action.ExerciseProps.Select(ep => ep.Prop?.PropName).Where(name => !string.IsNullOrWhiteSpace(name)))</div>
                        }
                        @if (!string.IsNullOrEmpty(action.Notes))
                        {
                            <div style="margin-bottom: 10px; background-color: white; padding: 8px; border-radius: 3px; border-left: 3px solid #007bff;"><strong>Notes:</strong> @action.Notes</div>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <p class="detailEmpty">No Exercises have been added yet.</p>
        }
    }

