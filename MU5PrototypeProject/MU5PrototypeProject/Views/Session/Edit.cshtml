                            <label asp-for="SessionsPerWeekRecommended" class="form-label"></label><span class="text-danger"> *</span>
                        <input asp-for="SessionsPerWeekRecommended" class="form-control" min="1" data-history-field="SessionsPerWeekRecommended" />
                        <span asp-validation-for="SessionsPerWeekRecommended" class="text-danger"></span>
                    </div>
                    <div class="col-md-6"><label asp-for="SessionNotes.GeneralComments" class="form-label"></label><textarea asp-for="SessionNotes.GeneralComments" class="form-control" data-history-field="SessionNotes.GeneralComments"></textarea></div>
                    <div class="col-md-6">
                            <label asp-for="SessionNotes.SubjectiveReports" class="form-label"></label><span class="text-danger"> *</span>
                        <textarea asp-for="SessionNotes.SubjectiveReports" class="form-control" data-history-field="SessionNotes.SubjectiveReports"></textarea>
