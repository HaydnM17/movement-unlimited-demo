        </div>

        <div class="formSectionCard @(isLoggedStage ? "loggedSection" : null)">
            <div class="sectionCardHeader">
                <h2 class="sectionCardTitle">Exercises</h2>
                @if (isLoggedStage && !isSemiPrivate)
                {
                    <button type="submit"
                            name="@(currentStatus == SessionStatus.Opened ? "continueToAddAction" : "Status")"
                            value="@(currentStatus == SessionStatus.Opened ? "true" : activeStage.ToString())"
                            data-add-action-session-client-id="@Model.PrimarySessionClientID"
                            class="mu-btn mu-btn-primary mu-btn-sm">+ Add Exercise</button>
                }
            </div>
            @{
                var primaryActions = Model.ExistingActions
                    .Where(a => a.SessionClientID == Model.PrimarySessionClientID
                        || a.SessionClient?.ParticipantOrder == 1)
                    .OrderBy(a => a.ID)
                    .ToList();
                var secondaryActions = Model.ExistingActions
                    .Where(a => a.SessionClientID == Model.SecondarySessionClientID
                        || a.SessionClient?.ParticipantOrder == 2)
                    .OrderBy(a => a.ID)
                    .ToList();
            }
            @if (activeStage == SessionStatus.Logged)
            {
                <span asp-validation-for="SelectedExerciseIDs" class="text-danger"></span>
                @if (isSemiPrivate)
                {
                    @foreach (var participantActions in new[] {
                        ("Client 1", Model.PrimarySessionClientID, primaryActions),
                        ("Client 2", Model.SecondarySessionClientID, secondaryActions)
                    })
                    {
                        <div class="actionsParticipantHeader">
                            <h3 class="sectionCardTitle mb-0" style="font-size: 1.05rem;">@participantActions.Item1</h3>
                            <button type="submit"
                                    name="@(currentStatus == SessionStatus.Opened ? "continueToAddAction" : "Status")"
                                    value="@(currentStatus == SessionStatus.Opened ? "true" : activeStage.ToString())"
                                    data-add-action-session-client-id="@participantActions.Item2"
                                    class="mu-btn mu-btn-primary mu-btn-sm">+ Add Exercise</button>
                        </div>
                        @if (participantActions.Item3.Any())
                        {
                            <div class="actionGridCompact" style="margin-bottom: 16px;">
                                @foreach (var action in participantActions.Item3)
                                {
                                    <div class="actionCardCompact">
                                        <h4 class="actionCardTitle">@(action.Exercise?.ExerciseName ?? "Exercise")</h4>
                                        @if (action.Exercise?.Apparatus != null)
                                        {
                                            <div class="actionMetaRow"><strong>Apparatus:</strong> @action.Exercise.Apparatus.ApparatusName</div>
                                        }
                                        @if (!string.IsNullOrEmpty(action.Springs))
                                        {
                                            <div class="actionMetaRow"><strong>Springs:</strong> @action.Springs</div>
                                        }
                                        @if (action.ExerciseProps != null && action.ExerciseProps.Any())
                                        {
                                            <div class="actionMetaRow"><strong>Props:</strong> @string.Join(", ", action.ExerciseProps.Select(ep => ep.Prop?.PropName).Where(name => !string.IsNullOrWhiteSpace(name)))</div>
                                        }
                                        @if (!string.IsNullOrEmpty(action.Notes))
                                        {
                                            <div class="actionNotesCompact"><strong>Notes:</strong> @action.Notes</div>
                                        }
                                        <div class="actionFooterCompact">
                                            <a asp-action="EditAction" asp-route-id="@action.ID" class="mu-btn mu-btn-primary mu-btn-sm">Edit</a>
                                            <a asp-action="DeleteAction" asp-route-id="@action.ID" class="mu-btn mu-btn-danger mu-btn-sm" onclick="return confirm('Are you sure?')">Delete</a>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="detailEmpty">No Exercises have been added yet.</p>
                        }
                    }
                }
                else
                {
                    @if (primaryActions.Any())
                    {
                        <div class="actionGridCompact">
                            @foreach (var action in primaryActions)
                            {
                                <div class="actionCardCompact">
                                    <h4 class="actionCardTitle">@(action.Exercise?.ExerciseName ?? "Exercise")</h4>
                                    @if (action.Exercise?.Apparatus != null)
                                    {
                                        <div class="actionMetaRow"><strong>Apparatus:</strong> @action.Exercise.Apparatus.ApparatusName</div>
                                    }
                                    @if (!string.IsNullOrEmpty(action.Springs))
                                    {
                                        <div class="actionMetaRow"><strong>Springs:</strong> @action.Springs</div>
                                    }
                                    @if (action.ExerciseProps != null && action.ExerciseProps.Any())
                                    {
                                        <div class="actionMetaRow"><strong>Props:</strong> @string.Join(", ", action.ExerciseProps.Select(ep => ep.Prop?.PropName).Where(name => !string.IsNullOrWhiteSpace(name)))</div>
                                    }
                                    @if (!string.IsNullOrEmpty(action.Notes))
                                    {
                                        <div class="actionNotesCompact"><strong>Notes:</strong> @action.Notes</div>
                                    }
                                    <div class="actionFooterCompact">
                                        <a asp-action="EditAction" asp-route-id="@action.ID" class="mu-btn mu-btn-primary mu-btn-sm">Edit</a>
                                        <a asp-action="DeleteAction" asp-route-id="@action.ID" class="mu-btn mu-btn-danger mu-btn-sm" onclick="return confirm('Are you sure?')">Delete</a>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="detailEmpty">No Exercises have been added yet.</p>
                    }
                }
            }
            else if (isSemiPrivate)
            {
                @foreach (var participantActions in new[] { ("Client 1", primaryActions), ("Client 2", secondaryActions) })
                {
                    <h3 class="sectionCardTitle" style="font-size: 1.05rem; margin-bottom: 12px;">@participantActions.Item1</h3>
                    @if (participantActions.Item2.Any())
                    {
                        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 15px; margin-bottom: 16px;">
                            @foreach (var action in participantActions.Item2)
                            {
                                <div style="border: 1px solid #dee2e6; border-radius: 4px; padding: 15px; background-color: #f9f9f9;">
                                    <h4 style="margin-top: 0; margin-bottom: 10px;">@(action.Exercise?.ExerciseName ?? "Exercise")</h4>
                                    @if (action.Exercise?.Apparatus != null)
                                    {
                                        <div style="margin-bottom: 8px;"><strong>Apparatus:</strong> @action.Exercise.Apparatus.ApparatusName</div>
                                    }
                                    @if (!string.IsNullOrEmpty(action.Springs))
                                    {
                                        <div style="margin-bottom: 8px;"><strong>Springs:</strong> @action.Springs</div>
                                    }
                                    @if (action.ExerciseProps != null && action.ExerciseProps.Any())
                                    {
                                        <div style="margin-bottom: 8px;"><strong>Props:</strong> @string.Join(", ", action.ExerciseProps.Select(ep => ep.Prop?.PropName).Where(name => !string.IsNullOrWhiteSpace(name)))</div>
                                    }
                                    @if (!string.IsNullOrEmpty(action.Notes))
                                    {
                                        <div style="margin-bottom: 10px; background-color: white; padding: 8px; border-radius: 3px; border-left: 3px solid #007bff;"><strong>Notes:</strong> @action.Notes</div>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="detailEmpty">No Exercises have been added yet.</p>
                    }
                }
            }
            else if (primaryActions.Any())
            {
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 15px;">
                    @foreach (var action in primaryActions)
                    {
                        <div style="border: 1px solid #dee2e6; border-radius: 4px; padding: 15px; background-color: #f9f9f9;">
                            <h4 style="margin-top: 0; margin-bottom: 10px;">@(action.Exercise?.ExerciseName ?? "Exercise")</h4>
                            @if (action.Exercise?.Apparatus != null)
                            {
                                <div style="margin-bottom: 8px;"><strong>Apparatus:</strong> @action.Exercise.Apparatus.ApparatusName</div>
                            }
                            @if (!string.IsNullOrEmpty(action.Springs))
                            {
                                <div style="margin-bottom: 8px;"><strong>Springs:</strong> @action.Springs</div>
                            }
                            @if (action.ExerciseProps != null && action.ExerciseProps.Any())
                            {
                                <div style="margin-bottom: 8px;"><strong>Props:</strong> @string.Join(", ", action.ExerciseProps.Select(ep => ep.Prop?.PropName).Where(name => !string.IsNullOrWhiteSpace(name)))</div>
                            }
                            @if (!string.IsNullOrEmpty(action.Notes))
                            {
                                <div style="margin-bottom: 10px; background-color: white; padding: 8px; border-radius: 3px; border-left: 3px solid #007bff;"><strong>Notes:</strong> @action.Notes</div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="detailEmpty">No Exercises have been added yet.</p>
            }
        </div>

        <div class="formSectionCard">
            <div class="sectionCardHeader">
                <h2 class="sectionCardTitle">Next Steps</h2>
            </div>
            @if (activeStage == SessionStatus.Logged)
            {
                <div class="row g-3">
                    <div class="col-md-4"><label class="form-check-label"><input asp-for="NextSteps.NextAppointmentBooked" class="form-check-input" data-history-field="NextSteps.NextAppointmentBooked" /> Next Appointment Booked</label></div>
                    <div class="col-md-4"><label class="form-check-label"><input asp-for="NextSteps.CommunicatedProgress" class="form-check-input" data-history-field="NextSteps.CommunicatedProgress" /> Communicated Progress</label></div>
                    <div class="col-md-4"><label class="form-check-label"><input asp-for="NextSteps.ReadyToProgress" class="form-check-input" data-history-field="NextSteps.ReadyToProgress" /> Ready to Progress</label></div>
                    <div class="col-md-4"><label class="form-check-label"><input asp-for="NextSteps.CourseCorrectionNeeded" class="form-check-input" data-history-field="NextSteps.CourseCorrectionNeeded" /> Course Correction Needed</label></div>
                    <div class="col-md-4"><label class="form-check-label"><input asp-for="NextSteps.TeamConsult" class="form-check-input" data-history-field="NextSteps.TeamConsult" /> Team Consult</label></div>
                    <div class="col-md-4"><label class="form-check-label"><input asp-for="NextSteps.ReferredExternally" class="form-check-input" data-history-field="NextSteps.ReferredExternally" /> Referred Externally</label></div>
                    <div class="col-md-6">
                        <label asp-for="NextSteps.ReferredTo" class="form-label"></label>
                        <input asp-for="NextSteps.ReferredTo" class="form-control" data-history-field="NextSteps.ReferredTo" />
                        <span asp-validation-for="NextSteps.ReferredTo" class="text-danger"></span>
                    </div>
                </div>
            }
            else
            {
                <div class="detailFields">
                    <div class="detailField"><span class="detailFieldLabel">Next Appointment Booked</span><div class="detailFieldValue" data-history-field="NextSteps.NextAppointmentBooked" data-history-format="yesno">@YesNo(Model.NextSteps.NextAppointmentBooked)</div></div>
                    <div class="detailField"><span class="detailFieldLabel">Communicated Progress</span><div class="detailFieldValue" data-history-field="NextSteps.CommunicatedProgress" data-history-format="yesno">@YesNo(Model.NextSteps.CommunicatedProgress)</div></div>
                    <div class="detailField"><span class="detailFieldLabel">Ready to Progress</span><div class="detailFieldValue" data-history-field="NextSteps.ReadyToProgress" data-history-format="yesno">@YesNo(Model.NextSteps.ReadyToProgress)</div></div>
                    <div class="detailField"><span class="detailFieldLabel">Course Correction Needed</span><div class="detailFieldValue" data-history-field="NextSteps.CourseCorrectionNeeded" data-history-format="yesno">@YesNo(Model.NextSteps.CourseCorrectionNeeded)</div></div>
                    <div class="detailField"><span class="detailFieldLabel">Team Consult</span><div class="detailFieldValue" data-history-field="NextSteps.TeamConsult" data-history-format="yesno">@YesNo(Model.NextSteps.TeamConsult)</div></div>
                    <div class="detailField"><span class="detailFieldLabel">Referred Externally</span><div class="detailFieldValue" data-history-field="NextSteps.ReferredExternally" data-history-format="yesno">@YesNo(Model.NextSteps.ReferredExternally)</div></div>
                    <div class="detailField"><span class="detailFieldLabel">Referred To</span><div class="detailFieldValue" data-history-field="NextSteps.ReferredTo">@(string.IsNullOrWhiteSpace(Model.NextSteps.ReferredTo) ? "-" : Model.NextSteps.ReferredTo)</div></div>
                </div>
            }
        </div>
    }

    @if (activeStage == SessionStatus.Completed && isPhysio)
    {
        <div class="formSectionCard">
            <div class="sectionCardHeader">
                <h2 class="sectionCardTitle">Physio Info</h2>
            </div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="PhysioInfo!.PhysioAssessment" class="form-label"></label><span class="text-danger"> *</span>
                        <input asp-for="PhysioInfo!.PhysioAssessment" class="form-control" data-history-field="PhysioInfo.PhysioAssessment" />
                        <span asp-validation-for="PhysioInfo!.PhysioAssessment" class="text-danger"></span>
                    </div>
                <div class="col-md-6">
                    <label asp-for="PhysioInfo!.InsuranceCompany" class="form-label"></label><span class="text-danger"> *</span>
                        <input asp-for="PhysioInfo!.InsuranceCompany" class="form-control" data-history-field="PhysioInfo.InsuranceCompany" />
                        <span asp-validation-for="PhysioInfo!.InsuranceCompany" class="text-danger"></span>
                    </div>
                <div class="col-md-3">
                        <label asp-for="PhysioInfo!.CoverageAmountPerYear" class="form-label"></label><span class="text-danger"> *</span>
                        <input asp-for="PhysioInfo!.CoverageAmountPerYear" class="form-control" type="number" step="0.01" data-history-field="PhysioInfo.CoverageAmountPerYear" />
                        <span asp-validation-for="PhysioInfo!.CoverageAmountPerYear" class="text-danger"></span>
                    </div>
                <div class="col-md-3">
                        <label asp-for="PhysioInfo!.AmountUsed" class="form-label"></label><span class="text-danger"> *</span>
                        <input asp-for="PhysioInfo!.AmountUsed" class="form-control" type="number" step="0.01" data-history-field="PhysioInfo.AmountUsed" />
                        <span asp-validation-for="PhysioInfo!.AmountUsed" class="text-danger"></span>
                    </div>
                <div class="col-md-3">
                        <label asp-for="PhysioInfo!.CoverageResetsDate" class="form-label"></label><span class="text-danger"> *</span>
                        <input asp-for="PhysioInfo!.CoverageResetsDate" class="form-control" type="date" lang="en-CA" data-history-field="PhysioInfo.CoverageResetsDate" />
                        <span asp-validation-for="PhysioInfo!.CoverageResetsDate" class="text-danger"></span>
                    </div>
                <div class="col-md-3">
                        <label asp-for="PhysioInfo!.PhysiotherapistName" class="form-label"></label><span class="text-danger"> *</span>
                        <input asp-for="PhysioInfo!.PhysiotherapistName" class="form-control" data-history-field="PhysioInfo.PhysiotherapistName" />
                        <span asp-validation-for="PhysioInfo!.PhysiotherapistName" class="text-danger"></span>
                    </div>
                <div class="col-md-3"><label class="form-check-label"><input asp-for="PhysioInfo!.CoverageShared" class="form-check-input" data-history-field="PhysioInfo.CoverageShared" /> Coverage Shared</label></div>
                <div class="col-md-3"><label class="form-check-label"><input asp-for="PhysioInfo!.CommunicatedWithPhysio" class="form-check-input" data-history-field="PhysioInfo.CommunicatedWithPhysio" /> Communicated With Physio</label></div>
            </div>
        </div>
    }

    @if (currentStatus == SessionStatus.Logged)
    {
        <div class="formSectionCard historyViewerCard @(isLoggedStage ? "is-compact" : null)" data-history-viewer-container hidden>
            <div class="sectionCardHeader">
                <h2 class="sectionCardTitle">Previous Session Viewer</h2>
            </div>
            <div class="d-flex flex-wrap align-items-center gap-2">
                <button type="button" id="historyPreviousButton" class="mu-btn mu-btn-secondary historyNavButton" disabled>Previous</button>
                <button type="button" id="historyNextButton" class="mu-btn mu-btn-secondary historyNavButton" disabled>Next</button>
                <span id="historyStatusLabel" class="fieldNote mb-0">Current session values</span>
            </div>
            <div class="historyViewerMeta">
                <span id="historyCountLabel" class="historyViewerMetaItem">Previous Sessions: -</span>
            </div>
        </div>
    }

    @if (activeStage == SessionStatus.Completed)
    {
        <div class="formSectionCard">
            <div class="sectionCardHeader">
                <h2 class="sectionCardTitle">Admin Complete</h2>
            </div>
            <div class="row g-3">
                <div class="col-md-6">
                        <label asp-for="AdminComplete.AdminInitials" class="form-label"></label><span class="text-danger"> *</span>
                    <input asp-for="AdminComplete.AdminInitials" class="form-control" data-history-field="AdminComplete.AdminInitials" />
                    <span asp-validation-for="AdminComplete.AdminInitials" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                        <span class="form-label d-block" id="AdminComplete_IsPaid_Label">Has session been paid for?</span>
                    <div class="workflowChoiceGroup" role="radiogroup" aria-labelledby="AdminComplete_IsPaid_Label">
                        <label class="workflowChoice" for="AdminComplete_IsPaid_True">
                            <input id="AdminComplete_IsPaid_True" name="AdminComplete.IsPaid" type="radio" value="true" class="form-check-input" data-history-field="AdminComplete.IsPaid" @(Model.AdminComplete.IsPaid == true ? "checked" : null) />
                            <span>Yes</span>
                        </label>
                        <label class="workflowChoice" for="AdminComplete_IsPaid_False">
                            <input id="AdminComplete_IsPaid_False" name="AdminComplete.IsPaid" type="radio" value="false" class="form-check-input" data-history-field="AdminComplete.IsPaid" @(Model.AdminComplete.IsPaid == false ? "checked" : null) />
                            <span>No</span>
                        </label>
                    </div>
                    <span asp-validation-for="AdminComplete.IsPaid" class="text-danger"></span>
                </div>
                <div class="col-md-8">
                    <label asp-for="AdminComplete.AdminNotes" class="form-label"></label>
                    <textarea asp-for="AdminComplete.AdminNotes" class="form-control" data-history-field="AdminComplete.AdminNotes"></textarea>
                </div>
            </div>
        </div>
    }
    }

    <div class="formActions pageFooterActions workflowActionBar">
        <div class="workflowActionButtons">
            <input type="hidden" id="confirmation" name="confirmation" value="confirm" />
            @if (showNextWorkflowButton)
            {
                <a asp-action="Edit"
                   asp-route-id="@Model.ID"
                   asp-route-workflowStatus="@nextWorkflowStatus"
                   class="mu-btn mu-btn-secondary workflowActionButton">
                    @nextWorkflowLabel
                </a>
            }
            @if (showWorkflowSubmitButton)
            {
                <button type="submit"
                        name="Status"
                        id="btnConfirm"
                        value="@activeStage"
                        class="mu-btn mu-btn-accent is-selected workflowActionButton">
                    @mainSaveLabel
                </button>
            }
            <button type="button"
                    id="btnFill"
                    class="mu-btn mu-btn-secondary is-selected workflowActionButton"
                    onclick="FillCreate()">
                Fill Fields
            </button>
        </div>
        <a asp-action="Details" asp-route-id="@Model.ID" class="mu-btn mu-btn-secondary">View Details</a>
        <a asp-action="Index" class="mu-btn mu-btn-ghost">Back to Sessions</a>
    </div>
</form>

<div class="modal fade" id="mymodal" tabindex="-1" aria-labelledby="sessionEditConfirmTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered mu-modal-dialog">
        <div class="modal-content mu-modal">
            <div class="mu-modal-accent"></div>
            <div class="modal-header mu-modal-header">
                <div>
                    <span class="mu-modal-badge">Review Session</span>
                    <h2 class="modal-title mu-modal-title mu-modal-title-sm" id="sessionEditConfirmTitle">Confirm session details</h2>
                    <p class="mu-modal-copy">Please review the session details before saving it.</p>
                </div>
                <button type="button" class="btn-close mu-modal-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body mu-modal-body">
                @if (showWorkflowProgress)
                {
                    <partial name="_SessionWorkflowProgress" model="activeStage" />
                }
                <div class="detailFields clientConfirmGrid">
                </div>
            </div>
            <div class="modal-footer mu-modal-footer">
                <input id="btnsubmit" type="submit" form="pageForm" value="Confirm" class="mu-btn mu-btn-primary" />
                <button type="button" class="mu-btn mu-btn-ghost" data-bs-dismiss="modal">Back to Form</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
    
        function FillCreate() {

            if (@((int)Model.SessionType) == @((int)SessionType.SemiPrivate)){

                document.getElementById("Client2SessionNotes_Goals").value = "Final package session. Review progress."
                document.getElementById("Client2SessionNotes_GeneralComments").value = "";
                document.getElementById("Client2SessionNotes_SubjectiveReports").value = "Knee pain free for 2 weeks.";
                document.getElementById("Client2SessionNotes_ObjectiveFindings").value = "Full depth squat with good mechanics. Single leg stable.";
                document.getElementById("Client2SessionNotes_Plan").value = "Ready to progress to independent training with check-ins.";

                document.getElementById("Client2Accessories_HeadPad").value = 4;
                document.getElementById("Client2Accessories_StrapsOrHandles").value = 1;

                document.getElementById("Client2Accessories_GearBar").value = 2;
                document.getElementById("Client2Accessories_StopperSettings").value = 5;
            }

            document.getElementById("SessionNotes_Goals").value = "Posture and endurance review."
            document.getElementById("SessionNotes_GeneralComments").value = "Wants to continue. Booking next package.";
            document.getElementById("SessionNotes_SubjectiveReports").value = "No upper back pain this week.";
            document.getElementById("SessionNotes_ObjectiveFindings").value = "Posture significantly improved. Head neutral.";
            document.getElementById("SessionNotes_Plan").value = "Maintain current program. Add variety.";

            document.getElementById("Accessories_HeadPad").value = 2;
            document.getElementById("Accessories_StrapsOrHandles").value = 1;

            document.getElementById("Accessories_GearBar").value = 1;
            document.getElementById("Accessories_StopperSettings").value = 2;

            document.getElementById("SessionsPerWeekRecommended").value = 2;

        }

        (function () {
            const editForm = document.querySelector("form.editShell");
            const sessionTypeField = document.getElementById("SessionType");
            const semiPrivateValue = "@((int)SessionType.SemiPrivate)";
            const semiPrivateSections = document.querySelectorAll(".semiPrivateOnly");
            const semiPrivateFields = document.querySelectorAll(".semiPrivateOnly input, .semiPrivateOnly select, .semiPrivateOnly textarea");
            const historyPreviousButton = document.getElementById("historyPreviousButton");
            const historyNextButton = document.getElementById("historyNextButton");
            const historyStatusLabel = document.getElementById("historyStatusLabel");
            const historyCountLabel = document.getElementById("historyCountLabel");
            const historyViewerContainers = Array.from(document.querySelectorAll("[data-history-viewer-container]"));
            const historyActionsContainer = document.getElementById("historyActionsContainer");
            const saveButton = document.querySelector("button[type='submit'][name='Status']");
            const addActionSessionClientIdField = document.getElementById("addActionSessionClientId");
            const editableControls = editForm
                ? Array.from(editForm.querySelectorAll("input:not([type='hidden']), select, textarea, button"))
                    .filter(control =>
                        control !== historyPreviousButton
                        && control !== historyNextButton
                        && !control.matches("button[data-bs-toggle='collapse']"))
                : [];
            const workflowActionLinks = editForm
                ? Array.from(editForm.querySelectorAll(".workflowActionButtons a.workflowActionButton"))
                : [];
            const currentSessionId = @Model.ID;
            const currentSessionDate = "@Model.SessionDate.ToString("yyyy-MM-dd")";
            const primaryClientId = @(Model.ClientID?.ToString() ?? "null");
            const secondaryClientId = @(Model.Client2ID?.ToString() ?? "null");
            const isSemiPrivateSession = @(isSemiPrivate ? "true" : "false");
            const usesLoggedHistoryScope = @(currentStatus == SessionStatus.Logged ? "true" : "false");
            const actionHistoryUsesCompactLayout = @(activeStage == SessionStatus.Logged ? "true" : "false");
            const currentStateLabel = "Current session values";
            const emptyActionsMessage = "No Exercises have been added yet.";
            const historyFields = Array.from(document.querySelectorAll("[data-history-field]"));
            const originalState = new Map();
            const originalControlState = new Map();
            const originalActionLinkState = new Map();
            const historyCache = new Map();
            let originalActionsMarkup = historyActionsContainer ? historyActionsContainer.innerHTML : "";
            const primaryHistoryFieldNames = [
                "SessionNotes.Goals",
                "SessionNotes.GeneralComments",
                "SessionNotes.SubjectiveReports",
                "SessionNotes.ObjectiveFindings",
                "SessionNotes.Plan",
                "SessionsPerWeekRecommended",
                "NextSteps.NextAppointmentBooked",
                "NextSteps.CommunicatedProgress",
                "NextSteps.ReadyToProgress",
                "NextSteps.CourseCorrectionNeeded",
                "NextSteps.TeamConsult",
                "NextSteps.ReferredExternally",
                "NextSteps.ReferredTo",
                "AdminComplete.IsPaid",
                "AdminComplete.AdminNotes",
                "AdminComplete.AdminInitials",
                "Accessories.HeadPad",
                "Accessories.StrapsOrHandles",
                "Accessories.GearBar",
                "Accessories.StopperSettings",
                "Accessories.RubberPads",
                "Accessories.HeadRest",
                "Accessories.Towel",
                "Accessories.PosturePillow",
                "PhysioInfo.PhysioAssessment",
                "PhysioInfo.InsuranceCompany",
                "PhysioInfo.CoverageAmountPerYear",
                "PhysioInfo.AmountUsed",
                "PhysioInfo.CoverageResetsDate",
                "PhysioInfo.PhysiotherapistName",
                "PhysioInfo.CoverageShared",
                "PhysioInfo.CommunicatedWithPhysio"
            ];
            const secondaryHistoryFieldNames = [
                "Client2SessionNotes.Goals",
                "Client2SessionsPerWeekRecommended",
                "Client2SessionNotes.GeneralComments",
                "Client2SessionNotes.SubjectiveReports",
                "Client2SessionNotes.ObjectiveFindings",
                "Client2SessionNotes.Plan",
                "Client2Accessories.HeadPad",
                "Client2Accessories.StrapsOrHandles",
                "Client2Accessories.GearBar",
                "Client2Accessories.StopperSettings",
                "Client2Accessories.RubberPads",
                "Client2Accessories.HeadRest",
                "Client2Accessories.Towel",
                "Client2Accessories.PosturePillow"
            ];
            const loggedPrimaryHistoryFieldNames = [
                "AdminComplete.IsPaid",
                "AdminComplete.AdminNotes",
                "AdminComplete.AdminInitials",
                "PhysioInfo.PhysioAssessment",
                "PhysioInfo.InsuranceCompany",
                "PhysioInfo.CoverageAmountPerYear",
                "PhysioInfo.AmountUsed",
                "PhysioInfo.CoverageResetsDate",
                "PhysioInfo.PhysiotherapistName",
                "PhysioInfo.CoverageShared",
                "PhysioInfo.CommunicatedWithPhysio"
            ];
            const loggedSecondaryHistoryFieldNames = [];
            let currentOffset = -1;
            let totalHistoryCount = 0;
            let primaryHistoryCount = 0;
            let secondaryHistoryCount = 0;
            let historySummaryLoaded = false;
            let isDirty = false;
            let suppressDirtyTracking = false;
            let allowNavigationWithoutWarning = false;
            const completionAccordion = document.getElementById("sessionEditCompletionAccordion");
            const defaultHistoryAutoOpenPaneIds = [
                "collapseEditSessionNotes",
                "collapseEditAccessories",
                "collapseEditNextSteps",
                "collapseEditPhysioInfo",
                "collapseEditAdminComplete"
            ];
            const loggedHistoryAutoOpenPaneIds = [
                "collapseEditPhysioInfo",
                "collapseEditAdminComplete"
            ];
            const historyAutoOpenPaneIds = usesLoggedHistoryScope
                ? loggedHistoryAutoOpenPaneIds
                : defaultHistoryAutoOpenPaneIds;

            function setHistoryViewerVisibility(isVisible) {
                historyViewerContainers.forEach(container => {
                    container.hidden = !isVisible;
                });
            }

            function getPrimaryHistoryFieldNames() {
                return usesLoggedHistoryScope
                    ? loggedPrimaryHistoryFieldNames
                    : primaryHistoryFieldNames;
            }

            function getSecondaryHistoryFieldNames() {
                return usesLoggedHistoryScope
                    ? loggedSecondaryHistoryFieldNames
                    : secondaryHistoryFieldNames;
            }

            function isTrackedEditableControl(control) {
                if (!control || !editForm || !editForm.contains(control)) {
                    return false;
                }

                if (!(control instanceof HTMLInputElement
                    || control instanceof HTMLSelectElement
                    || control instanceof HTMLTextAreaElement)) {
                    return false;
                }

                return control.type !== "hidden"
                    && !control.disabled
                    && !control.readOnly;
            }

            function markDirty() {
                if (!allowNavigationWithoutWarning) {
                    isDirty = true;
                }
            }

            function allowIntentionalNavigation() {
                allowNavigationWithoutWarning = true;

                window.setTimeout(function () {
                    allowNavigationWithoutWarning = false;
                }, 1000);
            }

            function runProgrammaticUpdate(action) {
                suppressDirtyTracking = true;

                try {
                    action();
                } finally {
                    suppressDirtyTracking = false;
                }
            }

            function syncSections() {
                const isSemiPrivate = sessionTypeField && sessionTypeField.value === semiPrivateValue;

                semiPrivateSections.forEach(section => section.classList.toggle("d-none", !isSemiPrivate));
                semiPrivateFields.forEach(field => field.disabled = !isSemiPrivate);
            }

            function snapshotElement(element) {
                if (element.type === "checkbox" || element.type === "radio") {
                    return { checked: element.checked };
                }

                if ("value" in element) {
                    return { value: element.value };
                }

                return { text: element.textContent };
            }

            function restoreElement(element, state) {
                if (!state) {
                    return;
                }

                if (element.type === "checkbox" || element.type === "radio") {
                    element.checked = !!state.checked;
                    return;
                }

                if ("value" in element && Object.prototype.hasOwnProperty.call(state, "value")) {
                    element.value = state.value;
                    return;
                }

                if (Object.prototype.hasOwnProperty.call(state, "text")) {
                    element.textContent = state.text;
                }
            }

            function snapshotCurrentActionsState() {
                if (!historyActionsContainer) {
                    return;
                }

                originalActionsMarkup = historyActionsContainer.innerHTML;
            }

            function restoreCurrentActionsState() {
                if (!historyActionsContainer) {
                    return;
                }

                historyActionsContainer.innerHTML = originalActionsMarkup;
            }

            function escapeHtml(value) {
                return String(value ?? "")
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/\"/g, "&quot;")
                    .replace(/'/g, "&#39;");
            }

            function getHistoryActions(data) {
                return data && Array.isArray(data.actions) ? data.actions : [];
            }

            function renderCompactHistoryActionCard(action) {
                const propNames = Array.isArray(action?.propNames)
                    ? action.propNames.filter(name => typeof name === "string" && name.trim() !== "")
                    : [];

                return `
                    <div class="actionCardCompact">
                        <h4 class="actionCardTitle">${escapeHtml(action?.exerciseName || "Exercise")}</h4>
                        ${action?.apparatusName ? `<div class="actionMetaRow"><strong>Apparatus:</strong> ${escapeHtml(action.apparatusName)}</div>` : ""}
                        ${action?.springs ? `<div class="actionMetaRow"><strong>Springs:</strong> ${escapeHtml(action.springs)}</div>` : ""}
                        ${propNames.length ? `<div class="actionMetaRow"><strong>Props:</strong> ${escapeHtml(propNames.join(", "))}</div>` : ""}
                        ${action?.notes ? `<div class="actionNotesCompact"><strong>Notes:</strong> ${escapeHtml(action.notes)}</div>` : ""}
                    </div>`;
            }

            function renderDetailHistoryActionCard(action) {
                const propNames = Array.isArray(action?.propNames)
                    ? action.propNames.filter(name => typeof name === "string" && name.trim() !== "")
                    : [];

                return `
                    <div style="border: 1px solid #dee2e6; border-radius: 4px; padding: 15px; background-color: #f9f9f9;">
                        <h4 style="margin-top: 0; margin-bottom: 10px;">${escapeHtml(action?.exerciseName || "Exercise")}</h4>
                        ${action?.apparatusName ? `<div style="margin-bottom: 8px;"><strong>Apparatus:</strong> ${escapeHtml(action.apparatusName)}</div>` : ""}
                        ${action?.springs ? `<div style="margin-bottom: 8px;"><strong>Springs:</strong> ${escapeHtml(action.springs)}</div>` : ""}
                        ${propNames.length ? `<div style="margin-bottom: 8px;"><strong>Props:</strong> ${escapeHtml(propNames.join(", "))}</div>` : ""}
                        ${action?.notes ? `<div style="margin-bottom: 10px; background-color: white; padding: 8px; border-radius: 3px; border-left: 3px solid #007bff;"><strong>Notes:</strong> ${escapeHtml(action.notes)}</div>` : ""}
                    </div>`;
            }

            function renderHistoryActionsList(actions, includeBottomMargin) {
                if (!actions.length) {
                    return `<p class="detailEmpty">${emptyActionsMessage}</p>`;
                }

                if (actionHistoryUsesCompactLayout) {
                    const marginStyle = includeBottomMargin ? ` style="margin-bottom: 16px;"` : "";
                    return `<div class="actionGridCompact"${marginStyle}>${actions.map(renderCompactHistoryActionCard).join("")}</div>`;
                }

                const marginStyle = includeBottomMargin ? " margin-bottom: 16px;" : "";
                return `<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 15px;${marginStyle}">${actions.map(renderDetailHistoryActionCard).join("")}</div>`;
            }

            function renderHistoryParticipantActions(label, actions) {
                if (actionHistoryUsesCompactLayout) {
                    return `
                        <div class="actionsParticipantHeader">
                            <h3 class="sectionCardTitle mb-0" style="font-size: 1.05rem;">${escapeHtml(label)}</h3>
                        </div>
                        ${renderHistoryActionsList(actions, true)}`;
                }

                return `
                    <h3 class="sectionCardTitle" style="font-size: 1.05rem; margin-bottom: 12px;">${escapeHtml(label)}</h3>
                    ${renderHistoryActionsList(actions, true)}`;
            }

            function renderHistoryActions(primaryHistory, secondaryHistory) {
                if (!historyActionsContainer) {
                    return;
                }

                const primaryActions = getHistoryActions(primaryHistory);
                if (isSemiPrivateSession) {
                    const secondaryActions = getHistoryActions(secondaryHistory);
                    historyActionsContainer.innerHTML = [
                        renderHistoryParticipantActions("Client 1", primaryActions),
                        renderHistoryParticipantActions("Client 2", secondaryActions)
                    ].join("");
                    return;
                }

                historyActionsContainer.innerHTML = renderHistoryActionsList(primaryActions, false);
            }

            function formatDisplayValue(value, format) {
                if (format === "yesno") {
                    return value ? "Yes" : "No";
                }

                return value === null || value === undefined || value === "" ? "-" : String(value);
            }

            function applyValueToField(fieldName, value) {
                document.querySelectorAll(`[data-history-field="${fieldName}"]`).forEach(element => {
                    if (element.type === "checkbox") {
                        element.checked = !!value;
                        return;
                    }

                    if (element.type === "radio") {
                        element.checked = value !== null && value !== undefined && String(value) === element.value;
                        return;
                    }

                    if ("value" in element) {
                        element.value = value === null || value === undefined ? "" : String(value);
                        return;
                    }

                    element.textContent = formatDisplayValue(value, element.dataset.historyFormat);
                });
            }

            function clearHistoryFields(fieldNames) {
                fieldNames.forEach(fieldName => applyValueToField(fieldName, null));
            }

            function clearPrimaryHistory() {
                clearHistoryFields(getPrimaryHistoryFieldNames());
            }

            function clearSecondaryHistory() {
                clearHistoryFields(getSecondaryHistoryFieldNames());
            }

            function getHistoryCount(history) {
                return history && history.totalCount ? history.totalCount : 0;
            }

            function setHistorySummary(primaryHistory, secondaryHistory) {
                primaryHistoryCount = getHistoryCount(primaryHistory);
                secondaryHistoryCount = getHistoryCount(secondaryHistory);
                totalHistoryCount = Math.max(primaryHistoryCount, secondaryHistoryCount);
            }

            function updateHistoryMetaUi() {
                if (!historyCountLabel) {
                    return;
                }

                historyCountLabel.textContent = `Previous Sessions: ${historySummaryLoaded ? totalHistoryCount : "-"}`;
            }

            function snapshotLiveCurrentFieldState() {
                historyFields.forEach((element, index) => {
                    const snapshotId = element.dataset.historySnapshotId || String(index);
                    element.dataset.historySnapshotId = snapshotId;
                    originalState.set(snapshotId, snapshotElement(element));
                });
            }

            function snapshotCurrentState() {
                snapshotCurrentActionsState();
                snapshotLiveCurrentFieldState();

                editableControls.forEach((control, index) => {
                    control.dataset.historyControlId = String(index);
                    originalControlState.set(String(index), {
                        disabled: !!control.disabled,
                        readOnly: !!control.readOnly
                    });
                });

                workflowActionLinks.forEach((link, index) => {
                    link.dataset.historyActionId = String(index);
                    originalActionLinkState.set(String(index), {
                        tabIndex: link.hasAttribute("tabindex") ? link.getAttribute("tabindex") : null,
                        ariaDisabled: link.getAttribute("aria-disabled")
                    });
                });
            }

            function restoreCurrentState() {
                runProgrammaticUpdate(function () {
                    restoreCurrentActionsState();
                    historyFields.forEach(element => restoreElement(element, originalState.get(element.dataset.historySnapshotId)));
                    editableControls.forEach(control => {
                        const state = originalControlState.get(control.dataset.historyControlId);
                        if (!state) {
                            return;
                        }

                        control.disabled = state.disabled;
                        control.readOnly = state.readOnly;
                    });
                    workflowActionLinks.forEach(link => {
                        const state = originalActionLinkState.get(link.dataset.historyActionId);
                        link.classList.remove("history-disabled-action");

                        if (!state) {
                            return;
                        }

                        if (state.tabIndex === null) {
                            link.removeAttribute("tabindex");
                        } else {
                            link.setAttribute("tabindex", state.tabIndex);
                        }

                        if (state.ariaDisabled === null) {
                            link.removeAttribute("aria-disabled");
                        } else {
                            link.setAttribute("aria-disabled", state.ariaDisabled);
                        }
                    });
                    if (editForm) {
                        editForm.classList.remove("history-reference-mode");
                    }
                    syncSections();
                });
            }

            function setBrowsingState(isBrowsingHistory) {
                if (saveButton) {
                    saveButton.disabled = isBrowsingHistory;
                    saveButton.title = isBrowsingHistory ? "Return to current session values before saving." : "";
                }

                editableControls.forEach(control => {
                    const state = originalControlState.get(control.dataset.historyControlId);
                    if (!state) {
                        return;
                    }

                    control.disabled = isBrowsingHistory ? true : state.disabled;
                    control.readOnly = isBrowsingHistory ? true : state.readOnly;
                });

                workflowActionLinks.forEach(link => {
                    const state = originalActionLinkState.get(link.dataset.historyActionId);
                    if (isBrowsingHistory) {
                        link.classList.add("history-disabled-action");
                        link.setAttribute("aria-disabled", "true");
                        link.setAttribute("tabindex", "-1");
                        return;
                    }

                    link.classList.remove("history-disabled-action");
                    if (!state) {
                        return;
                    }

                    if (state.ariaDisabled === null) {
                        link.removeAttribute("aria-disabled");
                    } else {
                        link.setAttribute("aria-disabled", state.ariaDisabled);
                    }

                    if (state.tabIndex === null) {
                        link.removeAttribute("tabindex");
                    } else {
                        link.setAttribute("tabindex", state.tabIndex);
                    }
                });

                if (editForm) {
                    editForm.classList.toggle("history-reference-mode", isBrowsingHistory);
                }
            }

            function openCompletionAccordionPane(paneId) {
                if (!completionAccordion) {
                    return;
                }

                const pane = document.getElementById(paneId);
                if (!pane || pane.classList.contains("show")) {
                    return;
                }

                if (window.bootstrap && window.bootstrap.Collapse) {
                    window.bootstrap.Collapse.getOrCreateInstance(pane, { toggle: false }).show();
                    return;
                }

                pane.classList.add("show");
                const trigger = document.querySelector(`[data-bs-target="#${paneId}"]`);
                if (trigger) {
                    trigger.classList.remove("collapsed");
                    trigger.setAttribute("aria-expanded", "true");
                }
            }

            function openRelevantHistoryPane() {
                const targetPaneId = historyAutoOpenPaneIds.find(function (paneId) {
                    return !!document.getElementById(paneId);
                });

                if (!targetPaneId) {
