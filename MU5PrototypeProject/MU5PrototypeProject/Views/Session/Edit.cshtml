                                <div class="detailField"><span class="detailFieldLabel">Objective Findings</span><div class="detailFieldValue detailTextValue" data-history-field="Client2SessionNotes.ObjectiveFindings">@(string.IsNullOrWhiteSpace(Model.Client2SessionNotes?.ObjectiveFindings) ? "-" : Model.Client2SessionNotes!.ObjectiveFindings)</div></div>
