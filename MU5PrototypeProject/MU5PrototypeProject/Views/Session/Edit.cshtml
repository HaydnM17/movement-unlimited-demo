@using Microsoft.AspNetCore.Mvc.Rendering
@using MU5PrototypeProject.Models
@using MU5PrototypeProject.Security
@model MU5PrototypeProject.Models.ViewModels.SessionUpsertVM

@{
    var currentStatus = Model.CurrentStatus;
    var requestedStage = Model.Status;
    var isSemiPrivate = Model.SessionType == SessionType.SemiPrivate;
    var isPhysio = Model.SessionType == SessionType.Physio;
    var recordStatus = Model.IsArchived ? "Archived" : "Active";
    var canLogByRole = User.IsInRole(AppRoles.Owner) || User.IsInRole(AppRoles.Trainer);
    var canCompleteWorkflow = User.IsInRole(AppRoles.Owner) || User.IsInRole(AppRoles.Administration);
    var canStartLoggedStage = ViewData["CanStartLoggedStage"] is bool canStartLoggedStageValue
        ? canStartLoggedStageValue
        : canLogByRole;
    var completedOnlyAccessMessage = ViewData["CompletedOnlyAccessMessage"]?.ToString();
    var sessionDateAllowsLogged = Model.SessionDate.Date <= DateTime.Today;
    var activeStage = currentStatus == SessionStatus.Logged && canCompleteWorkflow
        ? SessionStatus.Completed
        : requestedStage;
    var canShowOpenedLoggedStage = currentStatus == SessionStatus.Opened && canStartLoggedStage && sessionDateAllowsLogged;
    var showLaterStageSections = activeStage != SessionStatus.Opened && (currentStatus != SessionStatus.Opened || canShowOpenedLoggedStage);
    var showOpenedFutureDateMessage = currentStatus == SessionStatus.Opened && canStartLoggedStage && !sessionDateAllowsLogged;
    var showOpenedRoleMessage = currentStatus == SessionStatus.Opened && !canStartLoggedStage;
    var showWorkflowSubmitButton = currentStatus != SessionStatus.Opened || canShowOpenedLoggedStage;
    var isLoggedStage = activeStage == SessionStatus.Logged;
    var showWorkflowProgress = currentStatus != SessionStatus.Completed;
    var useCompletionAccordionLayout = currentStatus == SessionStatus.Logged
        && activeStage == SessionStatus.Completed;
    var allowGeneralInfoEditing = false;

    Func<SessionStatus, string> workflowBadgeClass = status => $"workflowBadge is-{status.ToString().ToLowerInvariant()}";
    string YesNo(bool value) => value ? "Yes" : "No";
    string LookupText(object? listObject, int? value)
    {
        var items = listObject as IEnumerable<SelectListItem>;
        if (!value.HasValue)
        {
            return "Not assigned";
        }

        return items?.FirstOrDefault(i => i.Value == value.Value.ToString())?.Text ?? value.Value.ToString();
    }

    string mainSaveLabel = activeStage switch
    {
        SessionStatus.Opened => "Save as Opened",
        SessionStatus.Logged => "Save as Logged",
        SessionStatus.Completed => "Save as Completed",
        _ => $"Save as {activeStage}"
    };
    string stageTitle = activeStage switch
    {
        SessionStatus.Opened => "Admin Setup",
        SessionStatus.Logged => "Trainer Log",
        SessionStatus.Completed when currentStatus == SessionStatus.Completed => "Completed Session Details",
        SessionStatus.Completed => "Closing Review",
        _ => "Edit Session"
    };
    string stageLead = activeStage switch
    {
        SessionStatus.Opened => "Review the scheduled session setup before the trainer log begins.",
        SessionStatus.Logged => "Record exercises, SOAP notes, and next steps from the appointment.",
        SessionStatus.Completed when currentStatus == SessionStatus.Completed => "Review the finalized session record.",
        SessionStatus.Completed => "Finish the admin review, payment status, and closing notes.",
        _ => "Update the session workflow."
    };
    ViewData["Title"] = stageTitle;
    SessionStatus? nextWorkflowStatus = currentStatus switch
    {
        SessionStatus.Logged when canCompleteWorkflow => SessionStatus.Completed,
        _ => null
    };
    string? nextWorkflowLabel = nextWorkflowStatus switch
    {
        SessionStatus.Logged => "Continue to Log",
        SessionStatus.Completed => "Continue to Complete",
        _ => null
    };
    var showNextWorkflowButton = nextWorkflowStatus.HasValue
        && nextWorkflowStatus.Value != activeStage
        && !Model.IsArchived
        && !isLoggedStage;

    async Task RenderGeneralInfoBody()
    {
        if (allowGeneralInfoEditing)
        {
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="SessionType" class="form-label"></label>
                    <select asp-for="SessionType" class="form-control" asp-items="Html.GetEnumSelectList<SessionType>()"></select>
                    <span asp-validation-for="SessionType" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="SessionDate" class="form-label"></label>
                    <input asp-for="SessionDate" class="form-control" type="date" lang="en-CA" />
                    <span asp-validation-for="SessionDate" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="TrainerID" class="form-label"></label>
                    <select asp-for="TrainerID" class="form-control" asp-items="ViewBag.TrainerID">
                        <option value="">Select a Teacher</option>
                    </select>
                    <span asp-validation-for="TrainerID" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="ClientID" class="form-label"></label>
                    <select asp-for="ClientID" class="form-control" asp-items="ViewBag.ClientID">
                        <option value="">Select a Client</option>
                    </select>
                    <span asp-validation-for="ClientID" class="text-danger"></span>
                </div>
                <div class="col-md-4 semiPrivateOnly">
                    <label asp-for="Client2ID" class="form-label"></label>
                    <select asp-for="Client2ID" class="form-control" asp-items="ViewBag.ClientID">
                        <option value="">Select a Second Client</option>
                    </select>
                    <span asp-validation-for="Client2ID" class="text-danger"></span>
                </div>
            </div>
        }
        else
        {
            <div class="detailFields">
                <div class="detailField"><span class="detailFieldLabel">Session Type</span><div class="detailFieldValue">@Model.SessionType</div></div>
                <div class="detailField"><span class="detailFieldLabel">Session Date (YYYY-MM-DD)</span><div class="detailFieldValue">@Model.SessionDate.ToString("yyyy-MM-dd")</div></div>
                <div class="detailField"><span class="detailFieldLabel">Teacher</span><div class="detailFieldValue">@LookupText(ViewBag.TrainerID, Model.TrainerID)</div></div>
                <div class="detailField"><span class="detailFieldLabel">Client</span><div class="detailFieldValue">@LookupText(ViewBag.ClientID, Model.ClientID)</div></div>
                @if (isSemiPrivate)
                {
                    <div class="detailField"><span class="detailFieldLabel">Client 2</span><div class="detailFieldValue">@LookupText(ViewBag.ClientID, Model.Client2ID)</div></div>
                }
            </div>
        }
    }

    async Task RenderPreviousSessionViewerBody()
    {
        <div class="d-flex flex-wrap align-items-center gap-2">
            <button type="button" id="historyPreviousButton" class="mu-btn mu-btn-secondary historyNavButton" disabled>Previous</button>
            <button type="button" id="historyNextButton" class="mu-btn mu-btn-secondary historyNavButton" disabled>Next</button>
            <span id="historyStatusLabel" class="fieldNote mb-0">Current session values</span>
        </div>
        <div class="historyViewerMeta">
            <span id="historyCountLabel" class="historyViewerMetaItem">Previous Sessions: -</span>
        </div>
    }

