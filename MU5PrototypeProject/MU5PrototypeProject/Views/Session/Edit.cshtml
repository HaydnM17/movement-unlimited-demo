                    <div class="col-md-6">
                            <label asp-for="Accessories!.StrapsOrHandles" class="form-label"></label><span class="text-danger"> *</span>
                            <select asp-for="Accessories!.StrapsOrHandles" class="form-control" asp-items="Html.GetEnumSelectList<StrapOrHandleOption>()" data-history-field="Accessories.StrapsOrHandles">
