                            <span asp-validation-for="Accessories!.StrapsOrHandles" class="text-danger"></span>
                        </div>
                        <div class="col-md-3"><label asp-for="Accessories!.GearBar" class="form-label"></label><span class="text-danger"> *</span>
                            <input asp-for="Accessories!.GearBar" class="form-control" data-history-field="Accessories.GearBar" min="1" max="3" />
                            <span asp-validation-for="Accessories!.GearBar" class="text-danger"></span>
                        </div>
                        <div class="col-md-3"><label asp-for="Accessories!.StopperSettings" class="form-label"></label><span class="text-danger"> *</span>
                            <input asp-for="Accessories!.StopperSettings" class="form-control" data-history-field="Accessories.StopperSettings" min="1" max="6" />
                            <span asp-validation-for="Accessories!.StopperSettings" class="text-danger"></span>
                        </div>
                    <div class="col-md-3"><label class="form-check-label"><input asp-for="Accessories!.RubberPads" class="form-check-input" data-history-field="Accessories.RubberPads" /> Rubber Pads</label></div>
                    <div class="col-md-3"><label class="form-check-label"><input asp-for="Accessories!.HeadRest" class="form-check-input" data-history-field="Accessories.HeadRest" /> Head Rest</label></div>
                    <div class="col-md-3"><label class="form-check-label"><input asp-for="Accessories!.Towel" class="form-check-input" data-history-field="Accessories.Towel" /> Towel</label></div>
                    <div class="col-md-3"><label class="form-check-label"><input asp-for="Accessories!.PosturePillow" class="form-check-input" data-history-field="Accessories.PosturePillow" /> Posture Pillow</label></div>
