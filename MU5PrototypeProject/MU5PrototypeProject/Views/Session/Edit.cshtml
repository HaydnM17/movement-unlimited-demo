                                <div class="detailField"><span class="detailFieldLabel">Goals</span><div class="detailFieldValue detailTextValue" data-history-field="Client2SessionNotes.Goals">@(string.IsNullOrWhiteSpace(Model.Client2SessionNotes?.Goals) ? "-" : Model.Client2SessionNotes!.Goals)</div></div>
                                <div class="detailField"><span class="detailFieldLabel">Sessions/Week</span><div class="detailFieldValue" data-history-field="Client2SessionsPerWeekRecommended">@(Model.Client2SessionsPerWeekRecommended?.ToString() ?? "-")</div></div>
                                <div class="detailField"><span class="detailFieldLabel">General Comments</span><div class="detailFieldValue detailTextValue" data-history-field="Client2SessionNotes.GeneralComments">@(string.IsNullOrWhiteSpace(Model.Client2SessionNotes?.GeneralComments) ? "-" : Model.Client2SessionNotes!.GeneralComments)</div></div>
