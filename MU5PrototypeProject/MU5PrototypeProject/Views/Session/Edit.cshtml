                                <div class="col-md-6"><label class="form-check-label"><input asp-for="Client2Accessories.RubberPads" class="form-check-input" data-history-field="Client2Accessories.RubberPads" /> Rubber Pads</label></div>
                                <div class="col-md-6"><label class="form-check-label"><input asp-for="Client2Accessories.HeadRest" class="form-check-input" data-history-field="Client2Accessories.HeadRest" /> Head Rest</label></div>
                                <div class="col-md-6"><label class="form-check-label"><input asp-for="Client2Accessories.Towel" class="form-check-input" data-history-field="Client2Accessories.Towel" /> Towel</label></div>
                                <div class="col-md-6"><label class="form-check-label"><input asp-for="Client2Accessories.PosturePillow" class="form-check-input" data-history-field="Client2Accessories.PosturePillow" /> Posture Pillow</label></div>
                            </div>
                        }
                        else
                        {
                            <div class="detailFields mt-3">
                                <div class="detailField"><span class="detailFieldLabel">Head Rest</span><div class="detailFieldValue" data-history-field="Client2Accessories.HeadPad">@Model.Client2Accessories!.HeadPad</div></div>
                                <div class="detailField"><span class="detailFieldLabel">Straps/Handles</span><div class="detailFieldValue" data-history-field="Client2Accessories.StrapsOrHandles">@Model.Client2Accessories.StrapsOrHandles</div></div>
                                <div class="detailField"><span class="detailFieldLabel">Gear Bar</span><div class="detailFieldValue" data-history-field="Client2Accessories.GearBar">@Model.Client2Accessories.GearBar</div></div>
                                <div class="detailField"><span class="detailFieldLabel">Stopper Settings</span><div class="detailFieldValue" data-history-field="Client2Accessories.StopperSettings">@Model.Client2Accessories.StopperSettings</div></div>
                                <div class="detailField"><span class="detailFieldLabel">Rubber Pads</span><div class="detailFieldValue" data-history-field="Client2Accessories.RubberPads" data-history-format="yesno">@YesNo(Model.Client2Accessories.RubberPads)</div></div>
                                <div class="detailField"><span class="detailFieldLabel">Head Rest</span><div class="detailFieldValue" data-history-field="Client2Accessories.HeadRest" data-history-format="yesno">@YesNo(Model.Client2Accessories.HeadRest)</div></div>
                                <div class="detailField"><span class="detailFieldLabel">Towel</span><div class="detailFieldValue" data-history-field="Client2Accessories.Towel" data-history-format="yesno">@YesNo(Model.Client2Accessories.Towel)</div></div>
                                <div class="detailField"><span class="detailFieldLabel">Posture Pillow</span><div class="detailFieldValue" data-history-field="Client2Accessories.PosturePillow" data-history-format="yesno">@YesNo(Model.Client2Accessories.PosturePillow)</div></div>
                            </div>
                        }
                    </div>
                </div>
            }
            else if (activeStage == SessionStatus.Logged)
            {
                <div class="row g-3">
                    <div class="col-md-6">
                            <label asp-for="Accessories!.HeadPad" class="form-label"></label><span class="text-danger"> *</span>
                            <select asp-for="Accessories!.HeadPad" class="form-control" asp-items="Html.GetEnumSelectList<HeadPadOption>()" data-history-field="Accessories.HeadPad">
                                <option value="" >Select a head rest option</option>
                            </select>
                            <span asp-validation-for="Accessories!.HeadPad" class="text-danger"></span>
