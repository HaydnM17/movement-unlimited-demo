            async function initializeHistorySummary() {
                const hasClient = !!primaryClientId || (isSemiPrivateSession && !!secondaryClientId);

                if (!hasClient) {
                    historySummaryLoaded = true;
                    updateHistoryUi();
                    return;
                }

                try {
                    const primaryHistoryTask = primaryClientId
                        ? fetchHistory(primaryClientId, 0, "primary:0")
                        : Promise.resolve(null);
                    const secondaryHistoryTask = isSemiPrivateSession && secondaryClientId
                        ? fetchHistory(secondaryClientId, 0, "secondary:0")
                        : Promise.resolve(null);
                    const [primaryHistory, secondaryHistory] = await Promise.all([primaryHistoryTask, secondaryHistoryTask]);

                    setHistorySummary(primaryHistory, secondaryHistory);
                } catch (error) {
                    setHistorySummary(null, null);
                }

                historySummaryLoaded = true;
                updateHistoryUi();
            }

            async function showHistory(offset) {
                if (!primaryClientId && !(isSemiPrivateSession && secondaryClientId)) {
                    setHistorySummary(null, null);
                    updateHistoryUi();
                    return;
                }

                if (offset < 0) {
                    currentOffset = -1;
                    restoreCurrentState();
                    updateHistoryUi();
                    return;
                }

                try {
                    if (currentOffset < 0) {
                        snapshotCurrentActionsState();
                        snapshotLiveCurrentFieldState();
                    }

                    const primaryHistoryTask = primaryClientId
                        ? fetchHistory(primaryClientId, offset, `primary:${offset}`)
                        : Promise.resolve(null);
                    const secondaryHistoryTask = isSemiPrivateSession && secondaryClientId
                        ? fetchHistory(secondaryClientId, offset, `secondary:${offset}`)
                        : Promise.resolve(null);
                    const [primaryHistory, secondaryHistory] = await Promise.all([primaryHistoryTask, secondaryHistoryTask]);
                    const hasPrimaryHistory = !!(primaryHistory && primaryHistory.found !== false);
                    const hasSecondaryHistory = !!(secondaryHistory && secondaryHistory.found !== false);

                    setHistorySummary(
                        historyCache.get("primary:0"),
                        historyCache.get("secondary:0"));

                    if (!hasPrimaryHistory && !hasSecondaryHistory) {
                        currentOffset = -1;
                        restoreCurrentState();
                        updateHistoryUi();
                        return;
                    }

                    restoreCurrentState();
                    runProgrammaticUpdate(function () {
                        if (hasPrimaryHistory) {
                            applyPrimaryHistory(primaryHistory);
                        } else {
                            clearPrimaryHistory();
                        }

                        if (isSemiPrivateSession && secondaryClientId) {
                            if (hasSecondaryHistory) {
                                applySecondaryHistory(secondaryHistory);
                            } else {
                                clearSecondaryHistory();
                            }
                        }

                        if (!usesLoggedHistoryScope) {
                            renderHistoryActions(primaryHistory, secondaryHistory);
                        }
                        syncSections();
                    });

                    currentOffset = offset;
                    updateHistoryUi();
                } catch (error) {
                    currentOffset = -1;
                    restoreCurrentState();
                    updateHistoryUi();
                }
            }

