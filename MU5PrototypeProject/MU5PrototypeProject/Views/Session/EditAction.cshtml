@model MU5PrototypeProject.Models.ViewModels.ActionEditVM

<h2>Edit Excercise</h2>

<form asp-action="EditAction" method="post" id="editActionForm">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="ActionID" />
    <input type="hidden" asp-for="SessionID" />
    <input type="hidden" asp-for="SessionClientID" />

    <!-- Apparatus Filter -->
    <div class="mb-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <label class="form-label">Apparatus</label>
            <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#newApparatusModal">
                <i class="bi bi-plus-circle"></i> Add New Apparatus
            </button>
        </div>
        <select id="apparatusFilter" class="form-select">
            <option value="">-- All Apparatus --</option>
            @if (ViewBag.ApparatusID != null)
            {
                @foreach (var item in ViewBag.ApparatusID)
                {
                    <option value="@item.Value">@item.Text</option>
                }
            }
        </select>
    </div>

    <!-- Exercise Selection -->
    <div class="mb-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <label asp-for="ExerciseID" class="form-label"></label>
            <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#newExerciseModal">
                <i class="bi bi-plus-circle"></i> Add New Exercise
            </button>
        </div>
        <select asp-for="ExerciseID" class="form-select" asp-items="Model.ExerciseList" id="exerciseSelect">
            <option value="">-- Select exercise --</option>
        </select>
        <span asp-validation-for="ExerciseID" class="text-danger"></span>
    </div>

    <!-- Springs -->
    <div class="mb-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <label asp-for="Springs" class="form-label"></label>
            <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#newSpringModal">
                <i class="bi bi-plus-circle"></i> Add New Spring
            </button>
        </div>
        <select asp-for="Springs" class="form-select" id="springsSelect">
            <option value="">-- Select spring --</option>
        </select>
    </div>

    <!-- Props Selection - Tablet Friendly -->
    <div class="mb-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <label class="form-label">Props</label>
            <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#newPropModal">
                <i class="bi bi-plus-circle"></i> Add New Prop
            </button>
        </div>
        <div class="propsContainer">
            @if (Model.PropList != null)
            {
                @foreach (var prop in Model.PropList)
                {
                    <div class="prop-checkbox-wrapper">
                        <label class="form-check">
                            <input type="checkbox" name="SelectedPropIDs" value="@prop.Value" class="form-check-input"
                                   @(Model.SelectedPropIDs?.Contains(int.Parse(prop.Value)) == true ? "checked" : "") />
                            <span class="form-check-label">@prop.Text</span>
                        </label>
                    </div>
                }
            }
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" style="resize:none;"></textarea>
    </div>

    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a asp-action="Edit" asp-route-id="@Model.SessionID" class="btn btn-secondary">Cancel</a>
</form>

<!-- New Exercise Modal -->
<div class="modal fade" id="newExerciseModal" tabindex="-1" aria-labelledby="newExerciseLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title" id="newExerciseLabel">Add New Exercise</h3>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="newExerciseName" class="form-label">Exercise Name</label>
                    <input type="text" class="form-control" id="newExerciseName">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="addNewExercise()">Add Exercise</button>
            </div>
        </div>
    </div>
</div>

<!-- New Apparatus Modal -->
<div class="modal fade" id="newApparatusModal" tabindex="-1" aria-labelledby="newApparatusLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="newApparatusLabel">Add New Apparatus</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="newApparatusName" class="form-label">Apparatus Name</label>
                    <input type="text" class="form-control" id="newApparatusName">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="addNewApparatus()">Add Apparatus</button>
            </div>
        </div>
    </div>
</div>

<!-- New Spring Modal -->
<div class="modal fade" id="newSpringModal" tabindex="-1" aria-labelledby="newSpringLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="newSpringLabel">Add New Spring</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="newSpringName" class="form-label">Spring Name</label>
                    <input type="text" class="form-control" id="newSpringName">
                </div>
                <div class="mb-3">
                    <label for="newSpringApparatus" class="form-label">Apparatus <span class="text-danger">*</span></label>
                    <select class="form-select" id="newSpringApparatus">
                        <option value="">-- Select apparatus --</option>
                        @if (ViewBag.ApparatusID != null)
                        {
                            @foreach (var item in ViewBag.ApparatusID)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="addNewSpring()">Add Spring</button>
            </div>
        </div>
    </div>
</div>

<!-- New Prop Modal -->
<div class="modal fade" id="newPropModal" tabindex="-1" aria-labelledby="newPropLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="newPropLabel">Add New Prop</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="newPropName" class="form-label">Prop Name</label>
                    <input type="text" class="form-control" id="newPropName">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="addNewProp()">Add Prop</button>
            </div>
        </div>
    </div>
</div>

<style>
    .propsContainer {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 10px;
        max-height: 300px;
        overflow-y: auto;
        padding: 10px;
        border: 1px solid #dee2e6;
        border-radius: 4px;
    }

    .prop-checkbox-wrapper {
        display: flex;
        align-items: flex-start;
        padding: 8px;
        border-radius: 4px;
        cursor: pointer;
        transition: background-color 0.2s;
    }

    .prop-checkbox-wrapper:hover {
        background-color: #f8f9fa;
    }

    .prop-checkbox-wrapper .form-check {
        display: flex;
        align-items: center;
        margin: 0;
        width: 100%;
    }

    .prop-checkbox-wrapper .form-check-input {
        margin-right: 10px;
        margin-top: 0;
        flex-shrink: 0;
        cursor: pointer;
    }

    .prop-checkbox-wrapper .form-check-label {
        margin: 0;
        cursor: pointer;
        word-break: break-word;
        flex-grow: 1;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        let springsData = @Html.Raw(ViewBag.SpringsJson ?? "[]");
        const initialApparatusId = '@Model.ApparatusFilterID';
        const initialExerciseId = '@Model.ExerciseID';
        const initialSpring = '@Html.Raw(Model.Springs ?? "")';

        function populateSprings(apparatusId, selectedValue) {
            const select = document.getElementById('springsSelect');
            const filtered = apparatusId
                ? springsData.filter(s => s.apparatusID == apparatusId)
                : springsData;
            select.innerHTML = '<option value="">-- Select spring --</option>';
            filtered.forEach(s => {
                const opt = document.createElement('option');
                opt.value = s.springName;
                opt.textContent = s.springName;
                if (s.springName === selectedValue) opt.selected = true;
                select.appendChild(opt);
            });
        }

        async function filterExercisesByApparatus(apparatusId, keepExerciseId) {
            const url = '@Url.Action("GetExercisesByApparatus", "Session")' +
                (apparatusId ? '?apparatusId=' + apparatusId : '');
            const response = await fetch(url);
            const exercises = await response.json();
            const select = document.getElementById('exerciseSelect');
            select.innerHTML = '<option value="">-- Select exercise --</option>';
            exercises.forEach(e => {
                const opt = document.createElement('option');
                opt.value = e.id;
                opt.textContent = e.text;
                if (keepExerciseId && e.id == keepExerciseId) opt.selected = true;
                select.appendChild(opt);
            });
        }

        function addApparatusOptionToDropdowns(id, name) {
            const dropdowns = ['apparatusFilter', 'newSpringApparatus'];
            dropdowns.forEach(dropId => {
                const sel = document.getElementById(dropId);
                if (sel) {
                    const opt = document.createElement('option');
                    opt.value = id;
                    opt.textContent = name;
                    sel.appendChild(opt);
                }
            });
        }

        document.getElementById('apparatusFilter').addEventListener('change', function () {
            const apparatusId = this.value;
            filterExercisesByApparatus(apparatusId, null);
            populateSprings(apparatusId, null);
        });

        // On page load: pre-filter by current apparatus and restore selected values
        (async function () {
            if (initialApparatusId) {
                document.getElementById('apparatusFilter').value = initialApparatusId;
                await filterExercisesByApparatus(initialApparatusId, initialExerciseId);
                populateSprings(initialApparatusId, initialSpring);
            } else {
                populateSprings(null, initialSpring);
            }
        })();

        async function addNewExercise() {
            const name = document.getElementById('newExerciseName').value.trim();

            if (!name) {
                alert('Please enter an exercise name');
                return;
            }

            try {
                const response = await fetch('@Url.Action("CreateExerciseAjax", "Session")?' +
                    new URLSearchParams({
                        exerciseName: name
                    }),
                {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('[name="__RequestVerificationToken"]').value
                    }
                });

                const data = await response.json();

                if (response.ok) {
                    const select = document.getElementById('exerciseSelect');
                    const option = document.createElement('option');
                    option.value = data.id;
                    option.text = data.displayName;
                    select.appendChild(option);
                    select.value = data.id;

                    const exerciseModal = bootstrap.Modal.getInstance(document.getElementById('newExerciseModal'));
                    if (exerciseModal) exerciseModal.hide();
                    document.getElementById('newExerciseName').value = '';
                } else {
                    alert('Error: ' + (data.message || response.statusText));
                    console.error('Response:', data);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error adding exercise: ' + error.message);
            }
        }

        async function addNewApparatus() {
            const name = document.getElementById('newApparatusName').value.trim();

            if (!name) {
                alert('Please enter an apparatus name');
                return;
            }

            try {
                const response = await fetch('@Url.Action("CreateApparatusAjax", "Session")?' +
                    new URLSearchParams({
                        apparatusName: name
                    }),
                {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('[name="__RequestVerificationToken"]').value
                    }
                });

                const data = await response.json();

                if (response.ok) {
                    addApparatusOptionToDropdowns(data.id, data.name);

                    const apparatusModal = bootstrap.Modal.getInstance(document.getElementById('newApparatusModal'));
                    if (apparatusModal) apparatusModal.hide();
                    document.getElementById('newApparatusName').value = '';
                } else {
                    alert('Error: ' + (data.message || response.statusText));
                    console.error('Response:', data);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error adding apparatus: ' + error.message);
            }
        }

        async function addNewSpring() {
            const name = document.getElementById('newSpringName').value.trim();
            const apparatusId = document.getElementById('newSpringApparatus').value;

            if (!name) {
                alert('Please enter a spring name');
                return;
            }
            if (!apparatusId) {
                alert('Please select an apparatus for this spring');
                return;
            }

            try {
                const response = await fetch('@Url.Action("CreateSpringAjax", "Session")?' +
                    new URLSearchParams({
                        springName: name,
                        apparatusId: apparatusId
                    }),
                {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('[name="__RequestVerificationToken"]').value
                    }
                });

                const data = await response.json();

                if (response.ok) {
                    springsData.push({ apparatusID: data.apparatusID, springName: data.name });
                    const currentApparatus = document.getElementById('apparatusFilter').value;
                    populateSprings(currentApparatus || null, data.name);

                    const springModal = bootstrap.Modal.getInstance(document.getElementById('newSpringModal'));
                    if (springModal) springModal.hide();
                    document.getElementById('newSpringName').value = '';
                    document.getElementById('newSpringApparatus').value = '';
                } else {
                    alert('Error: ' + (data.message || response.statusText));
                    console.error('Response:', data);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error adding spring: ' + error.message);
            }
        }

        async function addNewProp() {
            const name = document.getElementById('newPropName').value.trim();

            if (!name) {
                alert('Please enter a prop name');
                return;
            }

            try {
                const response = await fetch('@Url.Action("CreatePropAjax", "Session")?' +
                    new URLSearchParams({
                        propName: name
                    }),
                {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('[name="__RequestVerificationToken"]').value
                    }
                });

                const data = await response.json();

                if (response.ok) {
                    const container = document.querySelector('.propsContainer');
                    const wrapper = document.createElement('div');
                    wrapper.className = 'prop-checkbox-wrapper';
                    wrapper.innerHTML = `
                        <label class="form-check">
                            <input type="checkbox" name="SelectedPropIDs" value="${data.id}" class="form-check-input" checked />
                            <span class="form-check-label">${data.name}</span>
                        </label>
                    `;
                    container.appendChild(wrapper);

                    const propModal = bootstrap.Modal.getInstance(document.getElementById('newPropModal'));
                    if (propModal) propModal.hide();
                    document.getElementById('newPropName').value = '';
                } else {
                    alert('Error: ' + (data.message || response.statusText));
                    console.error('Response:', data);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error adding prop: ' + error.message);
            }
        }
    </script>
}
